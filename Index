// Compute per-project metrics from DPR (same matching logic as Project Summary), cached.
function computeProjectMetrics(projId){
  if(!projId)return{dprCount:0,startDate:null,endDate:null,tat:null,finalStage:'—',weightedPct:0,status:'pending',lastDate:null};
  if(_povCache[projId])return _povCache[projId];

  // Attendance rows for this project → unique IDs
  const ah=D.att.h,ar=D.att.r;
  const A_UID=ci(ah,'UniqueID','unique id'),A_PID=ci(ah,'ProjectID','project id');
  const uniqueIds=new Set(ar.filter(x=>v(x,A_PID)===projId).map(x=>v(x,A_UID)).filter(Boolean));

  // DPR rows matching by unique id OR child id starting with projId
  const dh=D.dpr.h,dr=D.dpr.r;
  const D_CID=ci(dh,'ChildID','child'),D_PLAN=ci(dh,'WorkPlan','plan','work'),D_TASK=ci(dh,'CompletedTask','completed task'),D_PCT=ci(dh,'%','completion','percent'),D_TS=ci(dh,'Timestamp','time'),D_UID=ci(dh,'UniqueID','unique');
  const dprRows=dr.filter(x=>{const uid=v(x,D_UID),cid=v(x,D_CID);return uniqueIds.has(uid)||cid.startsWith(projId);});

  // Timeline from DPR timestamps
  const dates=dprRows.map(x=>parseDate(v(x,D_TS))).filter(Boolean).sort((a,b)=>a-b);
  const startDate=dates.length?dates[0]:null;
  const endDate=dates.length?dates[dates.length-1]:null;
  const today=new Date();today.setHours(0,0,0,0);
  const tat=startDate?Math.ceil((today-startDate)/(1000*60*60*24))+1:null;

  // Final update stage = last DPR entry's column B (fixed index 1); status reference = column D (index 3)
  const DPR_B=1, DPR_D=3;
  const dprSorted=[...dprRows].sort((a,b)=>{const da=parseDate(v(a,D_TS)),db=parseDate(v(b,D_TS));if(!da&&!db)return 0;if(!da)return 1;if(!db)return -1;return da-db;});
  const lastEntry=dprSorted.length?dprSorted[dprSorted.length-1]:null;
  const finalStage=lastEntry?(lv(lastEntry,DPR_B)||'—'):'—';
  const lastStatus=lastEntry?lv(lastEntry,DPR_D):'';
  const lastDate=lastEntry?parseDate(v(lastEntry,D_TS)):null;

  // Weighted completion vs global workplan template
  const wr=D.workplan.r;
  const tmpl=wr.filter(x=>(x[0]||'').trim()).map(x=>({plan:(x[0]||'').trim(),expectedPct:parseFloat((x[1]||'').trim())||0}));
  const norm=s=>s.trim().toLowerCase().replace(/[^a-z0-9]/g,'');
  let weightedCompleted=0,totalWeight=0;
  tmpl.forEach(({plan,expectedPct})=>{
    const pn=norm(plan);
    const matched=dprRows.filter(x=>{const dp=norm(v(x,D_PLAN));return dp===pn||dp.includes(pn)||pn.includes(dp);});
    totalWeight+=expectedPct;
    if(!matched.length)return;
    const sorted=[...matched].sort((a,b)=>{const da=parseDate(v(a,D_TS)),db=parseDate(v(b,D_TS));if(!da&&!db)return 0;if(!da)return 1;if(!db)return -1;return da-db;});
    const latest=sorted[sorted.length-1];
    const latestPct=parseFloat(v(latest,D_PCT))||0;
    const latestTask=v(latest,D_TASK).toLowerCase();
    if(latestTask.includes('complet')||latestPct>=100)weightedCompleted+=expectedPct;
    else weightedCompleted+=expectedPct*(latestPct/100);
  });
  const weightedPct=totalWeight>0?Math.round(weightedCompleted/totalWeight*100):0;

  // Status (Project Overview): no DPR → pending; any DPR entry → in process; weighted 100% → completed
  let status;
  if(!dprRows.length)status='pending';
  else if(weightedPct>=100)status='done';
  else status='wip';

  const res={dprCount:dprRows.length,startDate,endDate,tat,finalStage,lastStatus,weightedPct,status,lastDate};
  _povCache[projId]=res;
  return res;
}

// Compact city-wise table: City | Count | Size (numbers)
function povCityTable(cityCount,citySize){
  const cities=Object.keys(cityCount);
  if(!cities.length)return'<div class="empty">No data</div>';
  const ordered=cities.sort((a,b)=>(cityCount[b]||0)-(cityCount[a]||0));
  const totC=ordered.reduce((s,c)=>s+(cityCount[c]||0),0);
  const totS=ordered.reduce((s,c)=>s+Math.round(citySize[c]||0),0);
  const rows=ordered.map(c=>`<tr>
    <td style="font-size:12px">${c}</td>
    <td style="text-align:right;font-size:12px;font-weight:500">${cityCount[c]||0}</td>
    <td style="text-align:right;font-size:12px;color:var(--muted)">${Math.round(citySize[c]||0).toLocaleString()}</td>
  </tr>`).join('');
  return `<div style="max-height:300px;overflow-y:auto;">
    <table style="font-size:12px;">
      <thead><tr><th>City</th><th style="text-align:right;">Count</th><th style="text-align:right;">Size</th></tr></thead>
      <tbody>${rows}</tbody>
      <tfoot><tr style="border-top:1px solid var(--border2);">
        <td style="font-weight:600;font-size:12px;">Total</td>
        <td style="text-align:right;font-weight:600;font-size:12px;">${totC}</td>
        <td style="text-align:right;font-weight:600;font-size:12px;">${totS.toLocaleString()}</td>
      </tr></tfoot>
    </table>
  </div>`;
}

// Project update / delay report (days since last DPR update)
function povDelayReport({upNever,upOk,up7,up15,up30,totalProjects}){
  if(!totalProjects)return'<div class="empty">No data</div>';
  const delayed=up7+up15+up30;
  const line=(color,icon,text,count)=>`<tr>
    <td style="width:1%;"><i class="ti ${icon}" style="color:${color};font-size:15px;"></i></td>
    <td style="font-size:12px;">${text}</td>
    <td style="text-align:right;font-size:13px;font-weight:600;color:${color};white-space:nowrap;">${count}</td>
  </tr>`;
  const banner=`<div style="margin-bottom:12px;padding:10px 12px;background:rgba(231,76,60,0.1);border:1px solid rgba(231,76,60,0.25);border-radius:8px;font-size:12px;color:var(--text);">
    <strong style="color:#e74c3c;">${delayed}</strong> project${delayed===1?'':'s'} delayed — no DPR update in 7+ days${upNever?`, and <strong style="color:#8b92b0;">${upNever}</strong> never updated`:''}.
  </div>`;
  return banner+`<table style="font-size:12px;">
    <tbody>
      ${line('#e74c3c','ti-alert-octagon','Critically delayed — no update 30+ days',up30)}
      ${line('#f5a623','ti-alert-triangle','Delayed — no update 15–29 days',up15)}
      ${line('#f5a623','ti-clock-exclamation','Delayed — no update 7–14 days',up7)}
      ${line('#34c98a','ti-circle-check','Up to date — updated within 7 days',upOk)}
      ${line('#8b92b0','ti-clock-off','Never updated (no DPR yet)',upNever)}
    </tbody>
  </table>`;
}

function buildPOV(){
  const r=D.lead.r;
  const fCity=_povMS.city, fCluster=_povMS.cluster, fCityMgr=_povMS.citymgr, fPE=_povMS.pe, fStatus=_povMS.status;

  // Filter lead rows; gate on a real project (Project ID non-empty)
  const rows=r.filter(x=>{
    if(!lv(x,LEAD_COL.PID))return false;
    if(fCity.size&&!fCity.has(lv(x,LEAD_COL.CITY)))return false;
    if(fCluster.size&&!fCluster.has(lv(x,LEAD_COL.CLUSTER)))return false;
    if(fCityMgr.size&&!fCityMgr.has(lv(x,LEAD_COL.CITYMGR)))return false;
    if(fPE.size&&!fPE.has(lv(x,LEAD_COL.PE)))return false;
    if(fStatus.size&&!povProjectStatuses(x).some(t=>fStatus.has(t)))return false;
    return true;
  });

  // Filter indicator tag (count of filter groups with a selection)
  const activeFilters=[fCity,fCluster,fCityMgr,fPE,fStatus].filter(s=>s.size).length;
  const tag=document.getElementById('pov-filter-tag');
  if(tag){tag.style.display=activeFilters?'inline':'none';if(activeFilters)tag.textContent=`${activeFilters} filter${activeFilters>1?'s':''} active`;}

  // Cards
  const totalProjects=rows.length;
  let totalSize=0,assigned=0,notAssigned=0,completed=0,inProcess=0,pending=0,pendingAssigned=0,pendingNotAssigned=0;
  const cityCount={},citySize={};
  // Update-recency buckets (days since last DPR entry)
  let upNever=0,upOk=0,up7=0,up15=0,up30=0;
  const today=new Date();today.setHours(0,0,0,0);
  rows.forEach(x=>{
    const projId=lv(x,LEAD_COL.PID);
    const city=lv(x,LEAD_COL.CITY)||'Unknown';
    const size=povNum(lv(x,LEAD_COL.SIZE));
    const peAssigned=!!lv(x,LEAD_COL.PE);
    totalSize+=size;
    if(peAssigned)assigned++;else notAssigned++;
    cityCount[city]=(cityCount[city]||0)+1;
    citySize[city]=(citySize[city]||0)+size;
    const m=computeProjectMetrics(projId);
    if(m.status==='done')completed++;
    else if(m.status==='wip')inProcess++;
    else {pending++; if(peAssigned)pendingAssigned++; else pendingNotAssigned++;}
    // recency
    if(!m.dprCount||!m.lastDate)upNever++;
    else{const days=Math.floor((today-m.lastDate)/(1000*60*60*24));if(days>=30)up30++;else if(days>=15)up15++;else if(days>=7)up7++;else upOk++;}
  });

  document.getElementById('pov-metrics').innerHTML=
    metric('ti-building-skyscraper','Total Projects',totalProjects,'From Lead Tracker','#4f8ef7')+
    metric('ti-ruler-2','Total Project Size',Math.round(totalSize).toLocaleString(),'Sum of capacity','#9b6dff')+
    metricWithBar('ti-user-off','Not Assigned',notAssigned,`${totalProjects?Math.round(notAssigned/totalProjects*100):0}% of projects`,'#e74c3c',totalProjects?notAssigned/totalProjects*100:0,'#e74c3c')+
    metricWithBar('ti-circle-check','Completed',completed,`${totalProjects?Math.round(completed/totalProjects*100):0}% of projects`,'#34c98a',totalProjects?completed/totalProjects*100:0,'#34c98a')+
    metricWithBar('ti-loader','In Process',inProcess,`${totalProjects?Math.round(inProcess/totalProjects*100):0}% of projects`,'#f5a623',totalProjects?inProcess/totalProjects*100:0,'#f5a623')+
    metricWithBar('ti-clock','Pending',pending,`${pendingAssigned} actual (assigned) · ${pendingNotAssigned} not assigned`,'#e74c3c',totalProjects?pending/totalProjects*100:0,'#e74c3c');

  // Left: compact city-wise table (count + size in numbers)
  document.getElementById('pov-city-table').innerHTML=povCityTable(cityCount,citySize);
  // Right: project update / delay report
  document.getElementById('pov-delay-report').innerHTML=povDelayReport({upNever,upOk,up7,up15,up30,totalProjects});

  // Master table
  document.getElementById('pov-head').innerHTML='<tr><th>#</th><th>City</th><th>Project ID</th><th>Project Name</th><th>Capacity</th><th>PE</th><th>Process Start</th><th>Process End</th><th>TAT</th><th>Completion %</th><th>Final Update Stage</th><th>Remarks</th><th>Report</th></tr>';
  const tbody=document.getElementById('pov-body');
  if(!rows.length){tbody.innerHTML='<tr><td colspan="13" class="empty">No projects match the selected filters</td></tr>';return;}

  // Sort by City then Project Name
  const sortedRows=[...rows].sort((a,b)=>{
    const c=lv(a,LEAD_COL.CITY).localeCompare(lv(b,LEAD_COL.CITY));
    if(c!==0)return c;
    return lv(a,LEAD_COL.PNAME).localeCompare(lv(b,LEAD_COL.PNAME));
  });

  tbody.innerHTML=sortedRows.map((x,i)=>{
    const city=lv(x,LEAD_COL.CITY)||'—';
    const projId=lv(x,LEAD_COL.PID);
    const projName=lv(x,LEAD_COL.PNAME)||'—';
    const cap=lv(x,LEAD_COL.SIZE)||'—';
    const peVal=lv(x,LEAD_COL.PE);
    const m=computeProjectMetrics(projId);
    let stageBadge;
    if(m.status==='done')stageBadge='<span class="badge bg">✓ Completed</span>';
    else if(m.status==='wip')stageBadge='<span class="badge bo">⟳ In Process</span>';
    else stageBadge='<span class="badge bgr">— Pending</span>';
    const finalStageTxt=m.finalStage&&m.finalStage!=='—'?`<div style="font-size:11px;color:var(--muted);margin-top:4px;max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${m.finalStage.replace(/"/g,'&quot;')}">${m.finalStage}</div>`:'';
    const escId=projId.replace(/'/g,"\\'");
    const escName=projName.replace(/'/g,"\\'");
    const pct=m.weightedPct;
    const pctColor=pct>=100?'#34c98a':pct>0?'#f5a623':'#e74c3c';
    const pctCell=`<div style="display:flex;align-items:center;gap:8px;min-width:90px;">
      <div style="flex:1;height:6px;border-radius:3px;background:rgba(255,255,255,0.08);overflow:hidden;"><div style="width:${Math.min(pct,100)}%;height:100%;background:${pctColor};border-radius:3px;"></div></div>
      <span style="font-size:12px;font-weight:600;color:${pctColor};min-width:30px;text-align:right;">${pct}%</span>
    </div>`;
    const reportLink=`<a onclick="openProjectSummaryFor('${escId}','${escName}')" style="display:inline-flex;align-items:center;gap:4px;padding:3px 8px;background:rgba(79,142,247,0.15);color:#4f8ef7;border:1px solid rgba(79,142,247,0.3);border-radius:6px;font-size:11px;font-weight:500;text-decoration:none;cursor:pointer;"><i class="ti ti-external-link" style="font-size:12px;"></i>View Summary</a>`;
    return `<tr>
      <td style="color:var(--muted)">${i+1}</td>
      <td style="font-size:12px">${city}</td>
      <td><span class="badge bp">${projId}</span></td>
      <td style="font-weight:500;font-size:13px">${projName}</td>
      <td style="font-size:12px">${cap}</td>
      <td style="font-size:12px">${peVal?peVal:'<span style="color:#e74c3c;font-weight:500;">Not Assigned</span>'}</td>
      <td style="font-size:11px;white-space:nowrap">${m.startDate?fmtDate(m.startDate):'—'}</td>
      <td style="font-size:11px;white-space:nowrap">${m.endDate?fmtDate(m.endDate):'—'}</td>
      <td style="font-size:12px;font-weight:500">${m.tat!==null?m.tat+'d':'—'}</td>
      <td>${pctCell}</td>
      <td>${stageBadge}${finalStageTxt}</td>
      <td style="font-size:11px;color:var(--muted)">—</td>
      <td>${reportLink}</td>
    </tr>`;
  }).join('');
}

// Open a project in the existing Project Summary tab
