<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Ops Dashboard</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.10.0/dist/tabler-icons.min.css"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;min-height:100vh;}
:root{--bg:#0f1117;--bg2:#181c27;--surface:#1e2336;--surface2:#252b40;--border:rgba(255,255,255,0.08);--border2:rgba(255,255,255,0.15);--text:#f0f2f8;--muted:#8b92b0;--accent:#4f8ef7;--radius:10px;--radius-lg:16px;}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg);color:var(--text);}
.topbar{background:var(--bg2);border-bottom:1px solid var(--border);padding:12px 24px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;position:sticky;top:0;z-index:100;}
.logo{font-size:17px;font-weight:600;color:var(--accent);display:flex;align-items:center;gap:8px;}
.topbar-right{display:flex;align-items:center;gap:10px;}
#status-badge{font-size:11px;padding:4px 12px;border-radius:20px;background:rgba(245,166,35,0.15);color:#f5a623;border:1px solid rgba(245,166,35,0.3);}
#last-updated{font-size:11px;color:var(--muted);}
.btn-refresh{font-size:12px;padding:7px 16px;border-radius:var(--radius);border:none;background:var(--accent);color:#fff;cursor:pointer;display:inline-flex;align-items:center;gap:6px;}
.btn-refresh:hover{background:#3a7de0;}
.btn-refresh.spinning i{animation:spin 0.8s linear infinite;}



.clr-btn{font-size:11px;padding:5px 12px;border-radius:var(--radius);border:1px solid var(--border2);background:transparent;color:var(--muted);cursor:pointer;height:30px;}
.clr-btn:hover{color:var(--text);}

.main{padding:20px 24px;width:100%;}
.tabs{display:flex;gap:4px;background:var(--bg2);border-radius:var(--radius);padding:4px;margin-bottom:20px;overflow-x:auto;}
.tab{font-size:13px;padding:7px 16px;border-radius:8px;border:none;background:transparent;color:var(--muted);cursor:pointer;white-space:nowrap;display:flex;align-items:center;gap:6px;transition:all 0.15s;}
.tab.active{background:var(--surface);color:var(--text);}
.tab-content{display:none;}
.tab-content.active{display:block;}
.section-title{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.section-title::after{content:'';flex:1;height:1px;background:var(--border);}
.metrics{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:10px;margin-bottom:20px;}
.metric{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:16px 18px;position:relative;overflow:hidden;}
.metric::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--mc,var(--accent));}
.metric .micon{font-size:18px;color:var(--mc,var(--accent));margin-bottom:6px;}
.metric .mlbl{font-size:10px;color:var(--muted);margin-bottom:3px;text-transform:uppercase;letter-spacing:0.04em;}
.metric .mval{font-size:28px;font-weight:600;line-height:1;}
.metric .msub{font-size:10px;color:var(--muted);margin-top:4px;}
.charts-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:14px;margin-bottom:20px;}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:18px 20px;margin-bottom:14px;}
.card-title{font-size:13px;font-weight:500;color:var(--muted);margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.card-title i{color:var(--accent);font-size:15px;}
.table-wrap{overflow-x:auto;width:100%;}
table{width:100%;border-collapse:collapse;font-size:13px;}
th{text-align:left;font-size:11px;color:var(--muted);border-bottom:1px solid var(--border);padding:8px 12px;text-transform:uppercase;letter-spacing:0.04em;white-space:nowrap;}
td{padding:8px 12px;border-bottom:1px solid var(--border);vertical-align:middle;}
tr:last-child td{border-bottom:none;}
tr:hover td{background:var(--surface2);}
.badge{display:inline-flex;align-items:center;font-size:11px;padding:3px 9px;border-radius:20px;font-weight:500;}
.bg{background:rgba(52,201,138,0.15);color:#34c98a;border:1px solid rgba(52,201,138,0.25);}
.bb{background:rgba(79,142,247,0.15);color:#4f8ef7;border:1px solid rgba(79,142,247,0.25);}
.br{background:rgba(231,76,60,0.15);color:#e74c3c;border:1px solid rgba(231,76,60,0.25);}
.bo{background:rgba(245,166,35,0.15);color:#f5a623;border:1px solid rgba(245,166,35,0.25);}
.bp{background:rgba(155,109,255,0.15);color:#9b6dff;border:1px solid rgba(155,109,255,0.25);}
.bgr{background:rgba(139,146,176,0.15);color:#8b92b0;border:1px solid rgba(139,146,176,0.25);}
.pr-row{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
.pr-lbl{font-size:12px;min-width:130px;max-width:130px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.pr-track{flex:1;height:7px;background:var(--bg);border-radius:4px;overflow:hidden;}
.pr-fill{height:100%;border-radius:4px;transition:width 0.5s;}
.pr-cnt{font-size:12px;color:var(--muted);min-width:28px;text-align:right;}
.avatar{width:30px;height:30px;border-radius:50%;background:var(--surface2);display:inline-flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:var(--accent);flex-shrink:0;}
.empty{text-align:center;color:var(--muted);padding:32px;font-size:13px;}
#overlay{position:fixed;inset:0;background:rgba(15,17,23,0.97);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;z-index:9999;}
#overlay.hidden{display:none;}
.spin{width:36px;height:36px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin 0.8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg)}}
#overlay-txt{font-size:14px;color:var(--muted);}

/* Project Summary styles */
.proj-filter-bar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px;align-items:flex-end;}
.proj-search-wrap{position:relative;min-width:240px;}
.proj-search-wrap input{font-size:12px;padding:7px 12px;border:1px solid var(--border2);border-radius:var(--radius);background:var(--surface2);color:var(--text);outline:none;width:100%;}
.proj-search-wrap input:focus{border-color:var(--accent);}
.proj-dropdown{position:absolute;top:100%;left:0;right:0;background:var(--surface);border:1px solid var(--border2);border-radius:var(--radius);z-index:200;max-height:220px;overflow-y:auto;display:none;box-shadow:0 8px 24px rgba(0,0,0,0.4);}
.proj-dropdown.open{display:block;}
.proj-dropdown-item{padding:8px 12px;font-size:12px;cursor:pointer;border-bottom:1px solid var(--border);}
.proj-dropdown-item:last-child{border-bottom:none;}
.proj-dropdown-item:hover{background:var(--surface2);}
.proj-dropdown-item.no-results{color:var(--muted);cursor:default;}
.proj-dropdown-item mark{background:rgba(79,142,247,0.3);color:var(--accent);border-radius:2px;}
.btn-search{font-size:12px;padding:7px 18px;border-radius:var(--radius);border:none;background:var(--accent);color:#fff;cursor:pointer;display:inline-flex;align-items:center;gap:6px;height:32px;}
.btn-search:hover{background:#3a7de0;}
.proj-info-bar{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:16px;padding:12px 16px;background:var(--surface2);border-radius:var(--radius);font-size:12px;}
.proj-info-bar span{color:var(--muted);}
.proj-info-bar strong{color:var(--text);}
.progress-col{min-width:180px;}
.pbar-wrap{display:flex;align-items:center;gap:8px;}
.pbar{flex:1;height:6px;background:var(--bg2);border-radius:3px;overflow:hidden;}
.pbar-fill{height:100%;border-radius:3px;}
.pct-lbl{font-size:11px;color:var(--muted);min-width:32px;text-align:right;}
.wip-pct{font-size:11px;color:#f5a623;margin-left:4px;}
#proj-metrics{grid-template-columns:repeat(auto-fit,minmax(130px,1fr));}
@media(max-width:600px){.main{padding:12px;}.topbar{padding:10px 14px;}}
/* ── PE Filter Bar ─────────────────────────────────────────── */
.pe-filter-bar{display:flex;align-items:flex-end;gap:12px;flex-wrap:wrap;padding:12px 24px;background:var(--bg2);border-bottom:1px solid var(--border);position:sticky;top:49px;z-index:98;}
.pe-filter-group{display:flex;flex-direction:column;gap:4px;}
.pe-filter-group label{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;font-weight:500;white-space:nowrap;}
.pe-filter-group select,
.pe-filter-group input[type=date]{font-size:12px;padding:5px 10px;border:1px solid var(--border2);border-radius:var(--radius);background:var(--surface2);color:var(--text);cursor:pointer;outline:none;height:30px;min-width:130px;transition:border-color 0.15s,box-shadow 0.15s;}
.pe-filter-group select:focus,
.pe-filter-group input[type=date]:focus{border-color:var(--accent);box-shadow:0 0 0 2px rgba(79,142,247,0.15);}
.pe-fdivider{width:1px;height:30px;background:var(--border2);margin:0 2px;align-self:center;}
.pe-filter-actions{display:flex;flex-direction:column;gap:4px;}
.pe-filter-actions>.spacer{font-size:10px;color:transparent;display:block;height:14px;}
.pe-clr-btn{font-size:12px;padding:0 14px;border-radius:var(--radius);border:1px solid var(--border2);background:transparent;color:var(--muted);cursor:pointer;height:30px;display:inline-flex;align-items:center;gap:6px;transition:all 0.15s;white-space:nowrap;}
.pe-clr-btn:hover{color:var(--text);border-color:var(--border2);background:var(--surface2);}
.pe-active-tag{font-size:11px;color:var(--accent);padding:3px 10px;background:rgba(79,142,247,0.1);border-radius:20px;border:1px solid rgba(79,142,247,0.2);align-self:center;white-space:nowrap;margin-left:4px;}

/* ── POV Multi-Select ── */
.pov-ms{position:relative;min-width:150px;}
.pov-ms-control{display:flex;align-items:center;justify-content:space-between;gap:6px;font-size:12px;padding:5px 10px;border:1px solid var(--border2);border-radius:var(--radius);background:var(--surface2);color:var(--text);cursor:pointer;height:30px;min-width:150px;transition:border-color 0.15s,box-shadow 0.15s;}
.pov-ms-control:hover{border-color:var(--accent);}
.pov-ms.open .pov-ms-control{border-color:var(--accent);box-shadow:0 0 0 2px rgba(79,142,247,0.15);}
.pov-ms-control .pov-ms-text{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;}
.pov-ms-control .pov-ms-text.placeholder{color:var(--muted);}
.pov-ms-control i{font-size:13px;color:var(--muted);transition:transform 0.15s;flex-shrink:0;}
.pov-ms.open .pov-ms-control i{transform:rotate(180deg);}
.pov-ms-count{font-size:10px;font-weight:600;background:var(--accent);color:#fff;border-radius:10px;padding:1px 6px;flex-shrink:0;}
.pov-ms-panel{position:absolute;top:calc(100% + 4px);left:0;right:0;min-width:200px;background:var(--surface);border:1px solid var(--border2);border-radius:var(--radius);z-index:300;display:none;box-shadow:0 8px 24px rgba(0,0,0,0.45);overflow:hidden;}
.pov-ms.open .pov-ms-panel{display:block;}
.pov-ms-search{width:100%;font-size:12px;padding:8px 10px;border:none;border-bottom:1px solid var(--border);background:var(--surface2);color:var(--text);outline:none;}
.pov-ms-search::placeholder{color:var(--muted);}
.pov-ms-actions{display:flex;gap:8px;padding:6px 10px;border-bottom:1px solid var(--border);}
.pov-ms-actions button{font-size:11px;background:transparent;border:none;color:var(--accent);cursor:pointer;padding:0;}
.pov-ms-actions button:hover{text-decoration:underline;}
.pov-ms-options{max-height:220px;overflow-y:auto;}
.pov-ms-opt{display:flex;align-items:center;gap:8px;padding:7px 10px;font-size:12px;cursor:pointer;border-bottom:1px solid var(--border);}
.pov-ms-opt:last-child{border-bottom:none;}
.pov-ms-opt:hover{background:var(--surface2);}
.pov-ms-opt input{accent-color:var(--accent);cursor:pointer;margin:0;width:14px;height:14px;flex-shrink:0;}
.pov-ms-opt .lbl{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;}
.pov-ms-cnt{font-size:10px;font-weight:600;color:var(--muted);background:var(--bg);border-radius:10px;padding:1px 7px;flex-shrink:0;}

/* ── Reports dimension selector ── */
.rpt-dim-bar{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;}
.rpt-dim{font-size:12px;padding:8px 16px;border-radius:8px;border:1px solid var(--border2);background:var(--surface2);color:var(--muted);cursor:pointer;display:inline-flex;align-items:center;gap:6px;transition:all 0.15s;}
.rpt-dim:hover{color:var(--text);border-color:var(--accent);}
.rpt-dim.active{background:var(--accent);color:#fff;border-color:var(--accent);}

/* ── Project Monthly Report matrix ── */
.pmr-legend{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:14px;font-size:11px;color:var(--muted);align-items:center;}
.pmr-legend .lg{display:inline-flex;align-items:center;gap:6px;}
.pmr-legend .sw{width:12px;height:12px;border-radius:3px;display:inline-block;}
.pmr-wrap{max-height:72vh;overflow:auto;}
.pmr-table{border-collapse:separate;border-spacing:0;font-size:11px;min-width:max-content;}
.pmr-table th,.pmr-table td{padding:7px 8px;border-bottom:1px solid var(--border);white-space:nowrap;}
.pmr-table thead th{position:sticky;top:0;z-index:5;background:var(--surface2);color:var(--muted);font-size:10px;text-transform:uppercase;letter-spacing:.04em;}
.pmr-table thead th.dcol{text-align:center;min-width:118px;}
.pmr-table thead th.dcol .dn{font-size:13px;color:var(--text);}
.pmr-table thead th.dcol .dw{font-size:9px;opacity:.7;}
/* sticky info columns */
.pmr-c0{position:sticky;left:0;z-index:4;background:var(--surface);width:90px;min-width:90px;max-width:90px;overflow:hidden;text-overflow:ellipsis;}
.pmr-c1{position:sticky;left:90px;z-index:4;background:var(--surface);width:150px;min-width:150px;max-width:150px;overflow:hidden;text-overflow:ellipsis;font-weight:500;color:var(--text);}
.pmr-c2{position:sticky;left:240px;z-index:4;background:var(--surface);width:64px;min-width:64px;max-width:64px;text-align:right;color:var(--muted);}
.pmr-c3{position:sticky;left:304px;z-index:4;background:var(--surface);width:120px;min-width:120px;max-width:120px;overflow:hidden;text-overflow:ellipsis;border-right:2px solid var(--border2);}
.pmr-table thead th.pmr-c0,.pmr-table thead th.pmr-c1,.pmr-table thead th.pmr-c2,.pmr-table thead th.pmr-c3{z-index:6;background:var(--surface2);}
.pmr-cell{display:flex;flex-direction:column;gap:3px;align-items:center;text-align:center;border-radius:6px;padding:4px 5px;font-size:10px;line-height:1.25;min-height:30px;justify-content:center;}
.pmr-cell .pmr-sub{font-size:9px;opacity:.85;}
.pmr-cell .pmr-tags{display:flex;gap:3px;margin-top:1px;}
.pmr-cell .pmr-tg{font-size:8px;font-weight:700;padding:1px 4px;border-radius:4px;}
.pmr-red{background:rgba(231,76,60,.16);color:#ff7a6b;}
.pmr-orange{background:rgba(245,166,35,.16);color:#f5a623;}
.pmr-green{background:rgba(52,201,138,.16);color:#34c98a;}
.pmr-teal{background:rgba(56,178,210,.16);color:#3bc0d8;}
.pmr-grey{background:rgba(139,146,176,.14);color:#8b92b0;}
.pov-ms-opt mark{background:rgba(79,142,247,0.3);color:var(--accent);border-radius:2px;}
.pov-ms-empty{padding:12px;text-align:center;color:var(--muted);font-size:12px;}

</style>
</head>
<body>

<div id="overlay">
  <div class="spin"></div>
  <div id="overlay-txt">Connecting to Google Sheets…</div>
</div>

<div class="topbar">
  <div style="display:flex;align-items:center;gap:10px;">
    <div class="logo"><i class="ti ti-bolt"></i> Ops Dashboard</div>
    <span style="font-size:11px;color:var(--muted);">PE · Attendance · TBT · DPR · Projects</span>
  </div>
  <div class="topbar-right">
    <span id="status-badge">Loading…</span>
    <span id="last-updated"></span>
    <button class="btn-refresh" onclick="loadAll()"><i class="ti ti-refresh"></i> Refresh</button>
  </div>
</div>

<!-- GLOBAL FILTER BAR -->


<div class="main" id="main" style="display:none;">
  <div class="tabs">
    <button class="tab active" onclick="switchTab('pe',this)"><i class="ti ti-users"></i> PE Overview</button>
    <button class="tab" onclick="switchTab('att',this)"><i class="ti ti-calendar-check"></i> Attendance</button>
    <button class="tab" onclick="switchTab('tbt',this)"><i class="ti ti-clipboard-list"></i> TBT</button>
    <button class="tab" onclick="switchTab('dpr',this)"><i class="ti ti-file-report"></i> DPR</button>
    <button class="tab" onclick="switchTab('pov',this)"><i class="ti ti-layout-dashboard"></i> Project Overview</button>
    <button class="tab" onclick="switchTab('rpt',this)"><i class="ti ti-chart-pie"></i> Reports</button>
    <button class="tab" onclick="switchTab('pmr',this)"><i class="ti ti-calendar-month"></i> Monthly Report</button>
    <button class="tab" onclick="switchTab('proj',this)"><i class="ti ti-building-skyscraper"></i> Project Summary</button>
  </div>

  <!-- PE TAB -->
  <div id="tab-pe" class="tab-content active">
    <!-- PE Filter Bar — sticky below topbar -->
      <div class="pe-filter-bar">
        <div class="pe-filter-group">
          <label>Cluster Head</label>
          <select id="pe-f-cluster" onchange="buildPE()"><option value="">All Clusters</option></select>
        </div>
        <div class="pe-filter-group">
          <label>City Manager</label>
          <select id="pe-f-city" onchange="buildPE()"><option value="">All City Mgrs</option></select>
        </div>
        <div class="pe-fdivider"></div>
        <div class="pe-filter-group">
          <label>Attendance</label>
          <select id="pe-f-att" onchange="buildPE()">
            <option value="">All Status</option>
            <option value="full">Full (In+Out)</option>
            <option value="in">Check-in Only</option>
            <option value="absent">Absent</option>
          </select>
        </div>
        <div class="pe-filter-group">
          <label>Visit Status</label>
          <select id="pe-f-vstatus" onchange="buildPE()"><option value="">All Visits</option></select>
        </div>
        <div class="pe-fdivider"></div>
        <div class="pe-filter-group">
          <label>Month</label>
          <select id="pe-f-month" onchange="onPEMonthChange()"><option value="">All Months</option></select>
        </div>
        <div class="pe-filter-group">
          <label>Week</label>
          <select id="pe-f-week" onchange="onPEWeekChange()"><option value="">All Weeks</option></select>
        </div>
        <div class="pe-filter-group">
          <label>Date</label>
          <select id="pe-f-date" onchange="onPEDateChange()"><option value="">All Dates</option></select>
        </div>
        <div class="pe-fdivider"></div>
        <div class="pe-filter-actions">
          <span class="spacer"></span>
          <button class="pe-clr-btn" onclick="clearPEFilters()"><i class="ti ti-x" style="font-size:12px;"></i> Clear Filters</button>
        </div>
        <span id="pe-filter-tag" class="pe-active-tag" style="display:none;"></span>
      </div>
    <div style="padding:20px 24px 0;">
      <div class="section-title">PE Summary</div>
      <div class="metrics" id="pe-metrics"></div>
    </div>
    <div style="padding:0 24px 20px;">
      <div class="card">
        <div class="card-title"><i class="ti ti-table"></i> All Project Engineers</div>
        <div class="table-wrap"><table><thead id="pe-head"></thead><tbody id="pe-body"></tbody></table></div>
      </div>
    </div>
  </div>

  <!-- ATTENDANCE TAB -->
  <div id="tab-att" class="tab-content">
    <div class="section-title">Attendance Summary</div>
    <div class="metrics" id="att-metrics"></div>
    <div class="charts-grid">
      <div class="card"><div class="card-title"><i class="ti ti-building"></i> Project-wise Visits</div><div id="proj-bars"></div></div>
      <div class="card"><div class="card-title"><i class="ti ti-user-check"></i> PE Visit Count</div><div id="pe-visit-bars"></div></div>
    </div>
    <div class="card">
      <div class="card-title"><i class="ti ti-list-details"></i> Attendance Log</div>
      <div class="table-wrap"><table><thead id="att-head"></thead><tbody id="att-body"></tbody></table></div>
    </div>
  </div>

  <!-- TBT TAB -->
  <div id="tab-tbt" class="tab-content">
    <div class="section-title">TBT Summary</div>
    <div class="metrics" id="tbt-metrics"></div>
    <div class="charts-grid">
      <div class="card"><div class="card-title"><i class="ti ti-users-group"></i> Vendor-wise TBT</div><div id="tbt-bars"></div></div>
      <div class="card"><div class="card-title"><i class="ti ti-mail"></i> Mail Status</div><div id="tbt-mail-bars"></div></div>
    </div>
    <div class="card">
      <div class="card-title"><i class="ti ti-list-details"></i> TBT Log</div>
      <div class="table-wrap"><table><thead id="tbt-head"></thead><tbody id="tbt-body"></tbody></table></div>
    </div>
  </div>

  <!-- DPR TAB -->
