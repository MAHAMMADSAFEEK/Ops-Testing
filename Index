// ── REPORTS TAB ───────────────────────────────────────────────
// Reports filter bar: dependent multi-selects with counts + search (mirrors POV, separate state)
const RPT_MS_CFG={
  city:    {col:'CITY',    all:'All Cities',    ph:'Search cities…'},
  cluster: {col:'CLUSTER', all:'All Clusters',  ph:'Search clusters…'},
  citymgr: {col:'CITYMGR', all:'All City Mgrs', ph:'Search city managers…'},
  pe:      {col:'PE',      all:'All PEs',        ph:'Search PEs…'}
};
let _rptMS={city:new Set(),cluster:new Set(),citymgr:new Set(),pe:new Set()};
let _rptMSAll={city:[],cluster:[],citymgr:[],pe:[]};
let _rptMSCounts={city:{},cluster:{},citymgr:{},pe:{}};

function populateRPTFilters(){
  const r=D.lead.r;
  const sets={city:new Set(),cluster:new Set(),citymgr:new Set(),pe:new Set()};
  r.forEach(x=>{
    if(!lv(x,LEAD_COL.PID))return;
    const c=lv(x,LEAD_COL.CITY); if(c)sets.city.add(c);
    const ch=lv(x,LEAD_COL.CLUSTER); if(ch)sets.cluster.add(ch);
    const cm=lv(x,LEAD_COL.CITYMGR); if(cm)sets.citymgr.add(cm);
    const pe=lv(x,LEAD_COL.PE); if(pe)sets.pe.add(pe);
  });
  Object.keys(sets).forEach(k=>{
    _rptMSAll[k]=[...sets[k]].sort((a,b)=>a.localeCompare(b));
    _rptMS[k]=new Set([..._rptMS[k]].filter(v=>sets[k].has(v)));
  });
  Object.keys(RPT_MS_CFG).forEach(buildRPTMSWidget);
  recomputeRPTOptions();
}

function buildRPTMSWidget(key){
  const host=document.getElementById('rpt-ms-'+key);
  if(!host)return;
  const cfg=RPT_MS_CFG[key];
  host.innerHTML=`
    <div class="pov-ms-control" onclick="toggleRPTMS('${key}')">
      <span class="pov-ms-text placeholder" id="rpt-ms-text-${key}">${cfg.all}</span>
      <i class="ti ti-chevron-down"></i>
    </div>
    <div class="pov-ms-panel">
      <input type="text" class="pov-ms-search" id="rpt-ms-search-${key}" placeholder="${cfg.ph}" oninput="renderRPTMSOptions('${key}')" onclick="event.stopPropagation()"/>
      <div class="pov-ms-actions">
        <button onclick="event.stopPropagation();selectAllRPTMS('${key}')">Select all</button>
        <button onclick="event.stopPropagation();clearRPTMS('${key}')">Clear</button>
      </div>
      <div class="pov-ms-options" id="rpt-ms-options-${key}"></div>
    </div>`;
  renderRPTMSOptions(key);
  updateRPTMSControl(key);
}

function renderRPTMSOptions(key){
  const box=document.getElementById('rpt-ms-options-'+key);
  if(!box)return;
  const q=((document.getElementById('rpt-ms-search-'+key)||{}).value||'').trim().toLowerCase();
  const opts=_rptMSAll[key].filter(o=>!q||o.toLowerCase().includes(q));
  if(!opts.length){box.innerHTML='<div class="pov-ms-empty">No matches</div>';return;}
  const counts=_rptMSCounts[key]||{};
  const hl=(t)=>{if(!q)return t;const i=t.toLowerCase().indexOf(q);return i<0?t:t.slice(0,i)+'<mark>'+t.slice(i,i+q.length)+'</mark>'+t.slice(i+q.length);};
  box.innerHTML=opts.map(o=>{
    const checked=_rptMS[key].has(o)?'checked':'';
    const safe=o.replace(/"/g,'&quot;').replace(/'/g,"\\'");
    const cnt=counts[o]||0;
    return `<label class="pov-ms-opt" onclick="event.stopPropagation()"><input type="checkbox" ${checked} onchange="toggleRPTMSOption('${key}','${safe}')"/><span class="lbl" title="${o.replace(/"/g,'&quot;')}">${hl(o)}</span><span class="pov-ms-cnt">${cnt}</span></label>`;
  }).join('');
}

function toggleRPTMSOption(key,val){
  if(_rptMS[key].has(val))_rptMS[key].delete(val); else _rptMS[key].add(val);
  updateRPTMSControl(key); recomputeRPTOptions(); buildRPT();
}

// Click a report row to drill down (toggle that value into the dimension's filter)
function rptDrill(dimKey,val){
  if(_rptMS[dimKey].has(val))_rptMS[dimKey].delete(val); else _rptMS[dimKey].add(val);
  updateRPTMSControl(dimKey); recomputeRPTOptions(); buildRPT();
}

function rptRowPasses(x){
  if(!lv(x,LEAD_COL.PID))return false;
  if(_rptMS.city.size&&!_rptMS.city.has(lv(x,LEAD_COL.CITY)))return false;
  if(_rptMS.cluster.size&&!_rptMS.cluster.has(lv(x,LEAD_COL.CLUSTER)))return false;
  if(_rptMS.citymgr.size&&!_rptMS.citymgr.has(lv(x,LEAD_COL.CITYMGR)))return false;
  if(_rptMS.pe.size&&!_rptMS.pe.has(lv(x,LEAD_COL.PE)))return false;
  return true;
}
function rptRowPassesExcept(x,exceptKey){
  if(!lv(x,LEAD_COL.PID))return false;
  if(exceptKey!=='city'    && _rptMS.city.size    && !_rptMS.city.has(lv(x,LEAD_COL.CITY)))return false;
  if(exceptKey!=='cluster' && _rptMS.cluster.size && !_rptMS.cluster.has(lv(x,LEAD_COL.CLUSTER)))return false;
  if(exceptKey!=='citymgr' && _rptMS.citymgr.size && !_rptMS.citymgr.has(lv(x,LEAD_COL.CITYMGR)))return false;
  if(exceptKey!=='pe'      && _rptMS.pe.size      && !_rptMS.pe.has(lv(x,LEAD_COL.PE)))return false;
  return true;
}

function recomputeRPTOptions(){
  const r=D.lead.r;
  Object.keys(RPT_MS_CFG).forEach(key=>{
    const counts={}; const colIdx=LEAD_COL[RPT_MS_CFG[key].col];
    r.forEach(x=>{ if(rptRowPassesExcept(x,key)){ const val=lv(x,colIdx); if(val)counts[val]=(counts[val]||0)+1; } });
    const set=new Set(Object.keys(counts));
    _rptMS[key].forEach(v=>set.add(v));
    _rptMSAll[key]=[...set].sort((a,b)=>a.localeCompare(b));
    _rptMSCounts[key]=counts;
    renderRPTMSOptions(key);
  });
}

function selectAllRPTMS(key){
  const q=((document.getElementById('rpt-ms-search-'+key)||{}).value||'').trim().toLowerCase();
  _rptMSAll[key].filter(o=>!q||o.toLowerCase().includes(q)).forEach(o=>_rptMS[key].add(o));
  updateRPTMSControl(key); recomputeRPTOptions(); buildRPT();
}
function clearRPTMS(key){ _rptMS[key].clear(); updateRPTMSControl(key); recomputeRPTOptions(); buildRPT(); }
function updateRPTMSControl(key){
  const txt=document.getElementById('rpt-ms-text-'+key);
  if(!txt)return;
  const sel=_rptMS[key];
  if(!sel.size){txt.textContent=RPT_MS_CFG[key].all;txt.classList.add('placeholder');}
  else if(sel.size===1){txt.textContent=[...sel][0];txt.classList.remove('placeholder');}
  else {txt.textContent=`${sel.size} selected`;txt.classList.remove('placeholder');}
}
function toggleRPTMS(key){
  const host=document.getElementById('rpt-ms-'+key);
  if(!host)return;
  const wasOpen=host.classList.contains('open');
  document.querySelectorAll('.pov-ms.open,.rpt-ms.open').forEach(el=>el.classList.remove('open'));
  if(!wasOpen){host.classList.add('open');const s=document.getElementById('rpt-ms-search-'+key);if(s){s.value='';renderRPTMSOptions(key);setTimeout(()=>s.focus(),0);}}
}
document.addEventListener('click',e=>{
  if(!e.target.closest('.rpt-ms'))document.querySelectorAll('.rpt-ms.open').forEach(el=>el.classList.remove('open'));
});
function clearRPTFilters(){
  Object.keys(_rptMS).forEach(k=>{_rptMS[k].clear();updateRPTMSControl(k);});
  recomputeRPTOptions(); buildRPT();
}

const RPT_DIMS=[
  {key:'city',    label:'City',         col:'CITY',    icon:'ti-building'},
  {key:'cluster', label:'Cluster Head', col:'CLUSTER', icon:'ti-users-group'},
  {key:'citymgr', label:'City Manager', col:'CITYMGR', icon:'ti-user-cog'},
  {key:'pe',      label:'PE',           col:'PE',      icon:'ti-user'}
];
let _rptDim='city';
function setRPTDim(k){_rptDim=k;buildRPT();}

function buildRPT(){
  const dim=RPT_DIMS.find(d=>d.key===_rptDim)||RPT_DIMS[0];
  const dimBar=document.getElementById('rpt-dim-bar');
  if(dimBar)dimBar.innerHTML=RPT_DIMS.map(d=>`<button class="rpt-dim ${d.key===_rptDim?'active':''}" onclick="setRPTDim('${d.key}')"><i class="ti ${d.icon}"></i> ${d.label}-wise</button>`).join('');
  const titleEl=document.getElementById('rpt-table-title');
  if(titleEl)titleEl.textContent=dim.label+'-wise Report';

  // Active-filter indicator
  const activeFilters=[_rptMS.city,_rptMS.cluster,_rptMS.citymgr,_rptMS.pe].filter(s=>s.size).length;
  const ftag=document.getElementById('rpt-filter-tag');
  if(ftag){ftag.style.display=activeFilters?'inline':'none';if(activeFilters)ftag.textContent=`${activeFilters} filter${activeFilters>1?'s':''} active`;}

  const r=D.lead.r;
  const groups={};
  let tProjects=0,tSize=0,tCompleted=0,tInProcess=0,tPending=0,tNotAssigned=0;
  r.forEach(x=>{
    if(!rptRowPasses(x))return;
    let g=lv(x,LEAD_COL[dim.col]);
    if(!g)g=(dim.key==='pe')?'— Not Assigned':'(Blank)';
    if(!groups[g])groups[g]={count:0,size:0,completed:0,inProcess:0,pending:0,notAssigned:0};
    const size=povNum(lv(x,LEAD_COL.SIZE));
    const peAssigned=!!lv(x,LEAD_COL.PE);
    const m=computeProjectMetrics(lv(x,LEAD_COL.PID));
    const G=groups[g];
    G.count++; G.size+=size; if(!peAssigned)G.notAssigned++;
    if(m.status==='done')G.completed++; else if(m.status==='wip')G.inProcess++; else G.pending++;
    tProjects++; tSize+=size; if(!peAssigned)tNotAssigned++;
    if(m.status==='done')tCompleted++; else if(m.status==='wip')tInProcess++; else tPending++;
  });

  const metricsEl=document.getElementById('rpt-metrics');
  if(metricsEl)metricsEl.innerHTML=
    metric('ti-building-skyscraper','Total Projects',tProjects,'All projects','#4f8ef7')+
    metric('ti-ruler-2','Total Size',Math.round(tSize).toLocaleString(),'Sum of capacity','#9b6dff')+
    metricWithBar('ti-circle-check','Completed',tCompleted,`${tProjects?Math.round(tCompleted/tProjects*100):0}% of projects`,'#34c98a',tProjects?tCompleted/tProjects*100:0,'#34c98a')+
    metricWithBar('ti-loader','In Process',tInProcess,`${tProjects?Math.round(tInProcess/tProjects*100):0}% of projects`,'#f5a623',tProjects?tInProcess/tProjects*100:0,'#f5a623')+
    metricWithBar('ti-clock','Pending',tPending,`${tProjects?Math.round(tPending/tProjects*100):0}% of projects`,'#e74c3c',tProjects?tPending/tProjects*100:0,'#e74c3c')+
    metricWithBar('ti-user-off','Not Assigned',tNotAssigned,`${tProjects?Math.round(tNotAssigned/tProjects*100):0}% of projects`,'#e74c3c',tProjects?tNotAssigned/tProjects*100:0,'#e74c3c');

  document.getElementById('rpt-head').innerHTML=`<tr><th>#</th><th>${dim.label}</th><th style="text-align:right;">Projects</th><th style="text-align:right;">Size</th><th style="text-align:right;">Completed</th><th style="text-align:right;">In Process</th><th style="text-align:right;">Pending</th><th style="text-align:right;">Not Assigned</th><th style="min-width:130px;">Completion %</th></tr>`;
  const tbody=document.getElementById('rpt-body');
  const entries=Object.entries(groups).sort((a,b)=>b[1].count-a[1].count);
  if(!entries.length){tbody.innerHTML='<tr><td colspan="9" class="empty">No data</td></tr>';return;}
  tbody.innerHTML=entries.map(([g,G],i)=>{
    const pct=G.count?Math.round(G.completed/G.count*100):0;
    const col=pct>=75?'#34c98a':pct>=40?'#f5a623':'#e74c3c';
    const bar=`<div style="display:flex;align-items:center;gap:8px;"><div style="flex:1;height:6px;border-radius:3px;background:var(--bg);overflow:hidden;"><div style="width:${pct}%;height:100%;background:${col};border-radius:3px;"></div></div><span style="font-size:11px;font-weight:600;color:${col};min-width:32px;text-align:right;">${pct}%</span></div>`;
    const synthetic=(g==='— Not Assigned'||g==='(Blank)');
    const active=_rptMS[dim.key].has(g);
    const nameCell=synthetic
      ? `<td style="font-size:13px;font-weight:500">${g}</td>`
      : `<td style="font-size:13px;font-weight:500;cursor:pointer;color:${active?'#4f8ef7':'var(--text)'}" onclick="rptDrill('${dim.key}','${g.replace(/'/g,"\\'")}')" title="Click to filter by ${g.replace(/"/g,'&quot;')}">${g} <i class="ti ti-filter" style="font-size:11px;opacity:0.55;"></i></td>`;
    return `<tr>
      <td style="color:var(--muted)">${i+1}</td>
      ${nameCell}
      <td style="text-align:right;font-weight:600">${G.count}</td>
      <td style="text-align:right;color:var(--muted)">${Math.round(G.size).toLocaleString()}</td>
      <td style="text-align:right;"><span class="badge bg">${G.completed}</span></td>
      <td style="text-align:right;"><span class="badge bo">${G.inProcess}</span></td>
      <td style="text-align:right;"><span class="badge br">${G.pending}</span></td>
      <td style="text-align:right;color:#e74c3c;font-weight:500;">${G.notAssigned}</td>
      <td>${bar}</td>
    </tr>`;
  }).join('')+`<tr style="border-top:2px solid var(--border2);">
    <td></td><td style="font-weight:700;">Total</td>
    <td style="text-align:right;font-weight:700;">${tProjects}</td>
    <td style="text-align:right;font-weight:700;">${Math.round(tSize).toLocaleString()}</td>
    <td style="text-align:right;font-weight:700;color:#34c98a;">${tCompleted}</td>
    <td style="text-align:right;font-weight:700;color:#f5a623;">${tInProcess}</td>
    <td style="text-align:right;font-weight:700;color:#e74c3c;">${tPending}</td>
    <td style="text-align:right;font-weight:700;color:#e74c3c;">${tNotAssigned}</td>
    <td style="font-weight:700;">${tProjects?Math.round(tCompleted/tProjects*100):0}%</td>
  </tr>`;
}

// ── PROJECT MONTHLY REPORT ────────────────────────────────────
// Attendance fixed cols: A=UniqueID(0) B=Date(1) C=ProjName(2) D=ProjID(3) L=flag(11) M=visitStatus(12)
const ATT_COL={UID:0,DATE:1,PNAME:2,PID:3,L:11,M:12};
// TBT fixed cols already: A=UID(0) I=Date(8) M=TBT Report(12) N=DPR Report(13)
const PMR_TBT={UID:0,DATE:8,TBTREP:12,DPRREP:13};

function pmrKey(d){return d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate();}

function populatePMRFilters(){
  // Month options from attendance dates
  const months={};
  D.att.r.forEach(x=>{const d=parseDate(v(x,ATT_COL.DATE));if(d){const k=d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0');months[k]=d;}});
  const msel=document.getElementById('pmr-f-month');
  if(msel){
    const cur=msel.value;
    msel.innerHTML='';
    const keys=Object.keys(months).sort().reverse();
    keys.forEach(k=>{const o=document.createElement('option');o.value=k;o.textContent=months[k].toLocaleDateString('en-IN',{month:'long',year:'numeric'});msel.appendChild(o);});
    if(cur&&keys.includes(cur))msel.value=cur; else if(keys.length)msel.value=keys[0];
    if(!keys.length){const o=document.createElement('option');o.value='';o.textContent='No data';msel.appendChild(o);}
  }
  // City / Cluster / CM / PE from Lead Tracker
  const cities=[],clusters=[],cms=[],pes=[];
  D.lead.r.forEach(x=>{if(!lv(x,LEAD_COL.PID))return;
    const c=lv(x,LEAD_COL.CITY);if(c)cities.push(c);
    const ch=lv(x,LEAD_COL.CLUSTER);if(ch)clusters.push(ch);
    const cm=lv(x,LEAD_COL.CITYMGR);if(cm)cms.push(cm);
    const pe=lv(x,LEAD_COL.PE);if(pe)pes.push(pe);});
  fillSel('pmr-f-city',cities);fillSel('pmr-f-cluster',clusters);fillSel('pmr-f-citymgr',cms);fillSel('pmr-f-pe',pes);
}

function clearPMRFilters(){
  ['pmr-f-week','pmr-f-city','pmr-f-cluster','pmr-f-citymgr','pmr-f-pe'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  buildPMR();
}

function pmrEvalCell(rows,tbtInfo,dateObj,today){
  const future=dateObj>today;
  if(!rows||!rows.length){
    return future?{cls:'pmr-grey',label:'—',sub:'',tags:''}:{cls:'pmr-red',label:'No Update today',sub:'',tags:''};
  }
  const pr=m=>({'onsite visit':4,'without visit update':3,'no activity':2})[m]||(m?1:0);
  let chosen=null,mNorm='';
  rows.forEach(r=>{const m=v(r,ATT_COL.M).toLowerCase();if(!chosen||pr(m)>pr(mNorm)){chosen=r;mNorm=m;}});
  if(mNorm==='onsite visit'){const yes=rows.find(r=>v(r,ATT_COL.M).toLowerCase()==='onsite visit'&&v(r,ATT_COL.L).toLowerCase()==='yes');if(yes)chosen=yes;}
  const lVal=v(chosen,ATT_COL.L).toLowerCase();

  if(!mNorm)return future?{cls:'pmr-grey',label:'—',sub:'',tags:''}:{cls:'pmr-red',label:'No Update today',sub:'',tags:''};
  if(mNorm==='no activity')return {cls:'pmr-orange',label:'No Activity',sub:'',tags:''};
  if(mNorm==='onsite visit'){
    if(lVal==='yes'){
      const t=tbtInfo||{tbt:false,dpr:false};
      const tags=`<div class="pmr-tags"><span class="pmr-tg ${t.tbt?'pmr-green':'pmr-grey'}">TBT ${t.tbt?'✓':'—'}</span><span class="pmr-tg ${t.dpr?'pmr-green':'pmr-grey'}">DPR ${t.dpr?'✓':'—'}</span></div>`;
      return {cls:'pmr-green',label:'Onsite Visit',sub:'(TBT - DPR)',tags};
    }
    return {cls:'pmr-green',label:'Onsite Visit',sub:'(Other task)',tags:''};
  }
  if(mNorm==='without visit update')return {cls:'pmr-teal',label:'Without Visit Update',sub:'(TBT & DPR)',tags:''};
  // any other value → show raw
  return {cls:'pmr-grey',label:v(chosen,ATT_COL.M),sub:'',tags:''};
}

function buildPMR(){
  const msel=document.getElementById('pmr-f-month');
  const monthVal=msel?msel.value:'';
  const weekVal=(document.getElementById('pmr-f-week')||{}).value||'';
  const fCity=(document.getElementById('pmr-f-city')||{}).value||'';
  const fCluster=(document.getElementById('pmr-f-cluster')||{}).value||'';
  const fCityMgr=(document.getElementById('pmr-f-citymgr')||{}).value||'';
  const fPE=(document.getElementById('pmr-f-pe')||{}).value||'';

  const head=document.getElementById('pmr-head'),body=document.getElementById('pmr-body');
  const legend=document.getElementById('pmr-legend');
  if(legend)legend.innerHTML=[
    ['pmr-green','Onsite Visit'],['pmr-teal','Without Visit Update'],['pmr-orange','No Activity'],
    ['pmr-red','No Update'],['pmr-grey','No data / future']
  ].map(([c,t])=>`<span class="lg"><span class="sw ${c}"></span>${t}</span>`).join('')+
    '<span class="lg" style="margin-left:auto;">TBT/DPR ✓ = report present in TBT sheet (cols M & N)</span>';

  if(!monthVal){head.innerHTML='';body.innerHTML='<tr><td class="empty">No attendance data available</td></tr>';return;}

  const [yy,mm]=monthVal.split('-').map(Number);
  const daysInMonth=new Date(yy,mm,0).getDate();
  let dayStart=1,dayEnd=daysInMonth;
  if(weekVal){const w=Number(weekVal);dayStart=(w-1)*7+1;dayEnd=Math.min(w*7,daysInMonth);if(dayStart>daysInMonth){head.innerHTML='';body.innerHTML='<tr><td class="empty">No days in this week</td></tr>';return;}}
  const days=[];for(let d=dayStart;d<=dayEnd;d++)days.push(new Date(yy,mm-1,d));
  const today=new Date();today.setHours(0,0,0,0);

  // Index attendance + TBT for the selected month
  const attIdx={},uidToProj={};
  D.att.r.forEach(x=>{
    const pid=v(x,ATT_COL.PID),uid=v(x,ATT_COL.UID),d=parseDate(v(x,ATT_COL.DATE));
    if(uid&&pid)uidToProj[uid]=pid;
    if(!pid||!d||d.getFullYear()!==yy||d.getMonth()!==mm-1)return;
    const k=pid+'|'+pmrKey(d);(attIdx[k]=attIdx[k]||[]).push(x);
  });
  const tbtIdx={};
  D.tbt.r.forEach(x=>{
    const uid=v(x,PMR_TBT.UID),pid=uidToProj[uid],d=parseDate(v(x,PMR_TBT.DATE));
    if(!pid||!d||d.getFullYear()!==yy||d.getMonth()!==mm-1)return;
    const k=pid+'|'+pmrKey(d);const cur=tbtIdx[k]||{tbt:false,dpr:false};
    if(v(x,PMR_TBT.TBTREP))cur.tbt=true; if(v(x,PMR_TBT.DPRREP))cur.dpr=true; tbtIdx[k]=cur;
  });

  // Project rows from Lead Tracker (filtered)
  const projRows=D.lead.r.filter(x=>{
    if(!lv(x,LEAD_COL.PID))return false;
    if(fCity&&lv(x,LEAD_COL.CITY)!==fCity)return false;
    if(fCluster&&lv(x,LEAD_COL.CLUSTER)!==fCluster)return false;
    if(fCityMgr&&lv(x,LEAD_COL.CITYMGR)!==fCityMgr)return false;
    if(fPE&&lv(x,LEAD_COL.PE)!==fPE)return false;
    return true;
  }).sort((a,b)=>{const c=lv(a,LEAD_COL.CITY).localeCompare(lv(b,LEAD_COL.CITY));return c!==0?c:lv(a,LEAD_COL.PNAME).localeCompare(lv(b,LEAD_COL.PNAME));});

  // Header
  const wd=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  head.innerHTML='<tr>'+
    '<th class="pmr-c0">City</th><th class="pmr-c1">Project</th><th class="pmr-c2">Size</th><th class="pmr-c3">PE</th>'+
    days.map(d=>`<th class="dcol"><div class="dn">${d.getDate()}</div><div class="dw">${wd[d.getDay()]}</div></th>`).join('')+
    '</tr>';

  if(!projRows.length){body.innerHTML=`<tr><td class="empty" colspan="${4+days.length}">No projects match the selected filters</td></tr>`;return;}

  body.innerHTML=projRows.map(x=>{
    const pid=lv(x,LEAD_COL.PID);
    const city=lv(x,LEAD_COL.CITY)||'—';
    const pname=lv(x,LEAD_COL.PNAME)||'—';
    const size=lv(x,LEAD_COL.SIZE)||'—';
    const pe=lv(x,LEAD_COL.PE)||'<span style="color:#e74c3c;">Not Assigned</span>';
    const cells=days.map(d=>{
      const k=pid+'|'+pmrKey(d);
      const c=pmrEvalCell(attIdx[k],tbtIdx[k],d,today);
      return `<td><div class="pmr-cell ${c.cls}">${c.label}${c.sub?`<span class="pmr-sub">${c.sub}</span>`:''}${c.tags||''}</div></td>`;
    }).join('');
    return `<tr>
      <td class="pmr-c0" style="font-size:11px;">${city}</td>
      <td class="pmr-c1" title="${pname.replace(/"/g,'&quot;')}">${pname}<div style="font-size:9px;color:var(--muted);font-weight:400;">${pid}</div></td>
      <td class="pmr-c2">${size}</td>
      <td class="pmr-c3" style="font-size:11px;">${pe}</td>
      ${cells}
    </tr>`;
  }).join('');
}

loadAll();
