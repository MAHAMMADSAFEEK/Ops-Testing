// Does a lead row satisfy every selected filter EXCEPT the named one?
function povRowPassesExcept(x,exceptKey){
  if(!lv(x,LEAD_COL.PID))return false;
  if(exceptKey!=='city'    && _povMS.city.size    && !_povMS.city.has(lv(x,LEAD_COL.CITY)))return false;
  if(exceptKey!=='cluster' && _povMS.cluster.size && !_povMS.cluster.has(lv(x,LEAD_COL.CLUSTER)))return false;
  if(exceptKey!=='citymgr' && _povMS.citymgr.size && !_povMS.citymgr.has(lv(x,LEAD_COL.CITYMGR)))return false;
  if(exceptKey!=='pe'      && _povMS.pe.size      && !_povMS.pe.has(lv(x,LEAD_COL.PE)))return false;
  if(exceptKey!=='status'  && _povMS.status.size){ if(!povProjectStatuses(x).some(t=>_povMS.status.has(t)))return false; }
  return true;
}

// Dependent dropdowns: each filter's options + counts = values co-occurring with the OTHER filters' selections
function recomputePOVOptions(){
  const r=D.lead.r;
  Object.keys(POV_MS_CFG).forEach(key=>{
    const counts={};
    if(key==='status'){
      r.forEach(x=>{ if(povRowPassesExcept(x,key)){ povProjectStatuses(x).forEach(t=>counts[t]=(counts[t]||0)+1); } });
      _povMSAll[key]=POV_STATUSES.slice(); // always show all statuses, in fixed order
    } else {
      const colIdx=LEAD_COL[POV_MS_CFG[key].col];
      r.forEach(x=>{ if(povRowPassesExcept(x,key)){ const val=lv(x,colIdx); if(val)counts[val]=(counts[val]||0)+1; } });
      const set=new Set(Object.keys(counts));
      _povMS[key].forEach(v=>set.add(v)); // keep current selections visible
      _povMSAll[key]=[...set].sort((a,b)=>a.localeCompare(b));
    }
    _povMSCounts[key]=counts;
    renderPOVMSOptions(key);
  });
}

