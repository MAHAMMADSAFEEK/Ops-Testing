function buildPE(){
  const h=D.pe.h,r=D.pe.r;
  const NI=ci(h,'EmployeeName','name'),SI=ci(h,'SSEID','sse'),EI=ci(h,'Mailid','email','mail'),DI=ci(h,'Dept','department'),RI=ci(h,'Region'),CLI=ci(h,'Clusterhead','cluster'),CMI=ci(h,'CityManager','city');

  // Read PE-local filters
  const fCluster=(document.getElementById('pe-f-cluster')||{}).value||'';
  const fCity=(document.getElementById('pe-f-city')||{}).value||'';
  const fAtt=(document.getElementById('pe-f-att')||{}).value||'';
  const fMonth=parseInt((document.getElementById('pe-f-month')||{}).value||'')||0;
  const fWeek=parseInt((document.getElementById('pe-f-week')||{}).value||'')||0;
  const fDate=(document.getElementById('pe-f-date')||{}).value||'';
  const fVS=(document.getElementById('pe-f-vstatus')||{}).value||'';

  // Attendance columns
  const _AEI=ci(D.att.h,'UserEmail','email'),_ACI=ci(D.att.h,'CheckinTime','checkin'),_AOI=ci(D.att.h,'CheckoutTime','checkout'),_AVSI=ci(D.att.h,'VisitStatus','status'),_ADI=ci(D.att.h,'Date');

  // Filter attendance rows by date / month / week / visit status
  const filtAtt=D.att.r.filter(x=>{
    if(fVS&&v(x,_AVSI)!==fVS)return false;
    const cellDate=v(x,_ADI);
    if(fDate){if(!dateMatch(cellDate,fDate))return false;}
    else if(fMonth||fWeek){
      const d=attDateObjStatic(cellDate);
      if(!d)return false;
      if(fMonth){
        // fMonth is "YYYY-MM"
        const yr=d.getFullYear(),mo=String(d.getMonth()+1).padStart(2,'0');
        if(`${yr}-${mo}`!==fMonth)return false;
      }
      if(fWeek){
        const day=d.getDate();
        const weekOfDay=day<=7?1:day<=14?2:day<=21?3:day<=28?4:5;
        if(weekOfDay!==fWeek)return false;
      }
    }
    return true;
  });

  // Build per-email sets from filtered attendance
  const ciEmails=new Set(filtAtt.filter(x=>v(x,_ACI)).map(x=>v(x,_AEI).toLowerCase()));
  const fullEmails=new Set(filtAtt.filter(x=>v(x,_ACI)&&v(x,_AOI)).map(x=>v(x,_AEI).toLowerCase()));
  const visitMap={};filtAtt.forEach(x=>{const e=v(x,_AEI).toLowerCase();visitMap[e]=(visitMap[e]||0)+1;});

  // Visit Status counts per PE from filtered att
  const vsMap={};
  filtAtt.forEach(x=>{
    const e=(v(x,_AEI)||'').toLowerCase();
    if(!e)return;
    if(!vsMap[e])vsMap[e]={onsite:0,without:0,noact:0};
    const st=(v(x,_AVSI)||'').trim();
    if(st==='Onsite Visit')vsMap[e].onsite++;
    else if(st==='Without Visit Update')vsMap[e].without++;
    else if(st==='No Activity')vsMap[e].noact++;
  });

  // Check-in/out time per PE from filtered att
  function parseTime(t){if(!t)return null;const d=new Date('1970/01/01 '+t);return isNaN(d)?null:d;}
  function fmtTime(d){if(!d)return'—';return d.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',hour12:true});}
  function timeDiff(a,b){if(!a||!b)return'—';const diff=Math.round((b-a)/60000);const hh=Math.floor(diff/60),mm=diff%60;return hh>0?`${hh}h ${mm}m`:`${mm}m`;}
  const timeMap={};
  filtAtt.forEach(x=>{
    const e=(v(x,_AEI)||'').toLowerCase();
    if(!e)return;
    const ci_t=parseTime(v(x,_ACI)),co_t=parseTime(v(x,_AOI));
    if(!timeMap[e])timeMap[e]={minCI:null,maxCO:null};
    if(ci_t&&(!timeMap[e].minCI||ci_t<timeMap[e].minCI))timeMap[e].minCI=ci_t;
    if(co_t&&(!timeMap[e].maxCO||co_t>timeMap[e].maxCO))timeMap[e].maxCO=co_t;
  });

  // TBT/DPR links
  const TUI=ci(D.tbt.h,'Uniqueid','unique');
  const TBTLI=ci(D.tbt.h,'TBTReport','tbt report');
  const DPRLI=ci(D.tbt.h,'DPRReport','dpr report');
  function getLinkBtn(link,label){
    if(!link||!link.startsWith('http'))return'<span style="color:var(--muted);font-size:11px;">—</span>';
    return`<a href="${link}" target="_blank" style="display:inline-flex;align-items:center;gap:4px;padding:3px 8px;background:rgba(52,201,138,0.15);color:#34c98a;border:1px solid rgba(52,201,138,0.3);border-radius:6px;font-size:11px;font-weight:500;text-decoration:none;cursor:pointer;"><i class="ti ti-folder-open" style="font-size:12px;"></i>${label}</a>`;
  }

  // Filter PE master rows
  let filteredPE=r.filter(x=>{
    if(fCluster&&v(x,CLI)!==fCluster)return false;
    if(fCity&&v(x,CMI)!==fCity)return false;
    return true;
  });

  // Filter by attendance status AFTER we know which emails qualify
  if(fAtt){
    filteredPE=filteredPE.filter(x=>{
      const email=v(x,EI).toLowerCase();
      if(fAtt==='full')return fullEmails.has(email);
      if(fAtt==='in')return ciEmails.has(email)&&!fullEmails.has(email);
      if(fAtt==='absent')return!ciEmails.has(email);
      return true;
    });
  }

  // Filter indicator
  const activeFilters=[fCluster,fCity,fAtt,fMonth?String(fMonth):'',fWeek?String(fWeek):'',fDate,fVS].filter(Boolean).length;
  const tag=document.getElementById('pe-filter-tag');
  if(tag){tag.style.display=activeFilters?'inline':'none';if(activeFilters)tag.textContent=`${activeFilters} filter${activeFilters>1?'s':''} active`;}

  const total=filteredPE.length;
  const ci_=filteredPE.filter(x=>ciEmails.has(v(x,EI).toLowerCase())).length;
  const full=filteredPE.filter(x=>fullEmails.has(v(x,EI).toLowerCase())).length;
  document.getElementById('pe-metrics').innerHTML=
    metric('ti-users','Total PEs',total,'','#4f8ef7')+
    metric('ti-login','Checked In',ci_,`${total?Math.round(ci_/total*100):0}%`,'#34c98a')+
    metric('ti-circle-check','Full Attendance',full,'In+Out','#9b6dff')+
    metric('ti-user-off','Absent',total-ci_,'No check-in','#e74c3c');

  document.getElementById('pe-head').innerHTML='<tr><th>#</th><th>Name</th><th>SSE ID</th><th>Dept</th><th>Region</th><th>Cluster</th><th>City Mgr</th><th>Attendance</th><th>Visits</th><th>Onsite Visit</th><th>Without Visit Update</th><th>No Activity</th><th>Total Activity</th><th>TBT</th><th>DPR</th><th>Check-In Time</th><th>Check-Out Time</th><th>Total Duration</th></tr>';
  const tbody=document.getElementById('pe-body');
  if(!filteredPE.length){tbody.innerHTML='<tr><td colspan="18" class="empty">No records match the selected filters</td></tr>';return;}
  tbody.innerHTML=filteredPE.map((x,i)=>{
    const email=v(x,EI).toLowerCase(),hasFull=fullEmails.has(email),hasIn=ciEmails.has(email);
    const attB=hasFull?'<span class="badge bg">Full</span>':hasIn?'<span class="badge bb">Check-in</span>':'<span class="badge br">Absent</span>';
    const name=v(x,NI)||'—',init=name.split(' ').map(w=>w[0]||'').join('').slice(0,2).toUpperCase(),sse=v(x,SI)||'';
    const vs=vsMap[email]||{onsite:0,without:0,noact:0};
    const totalAct=vs.onsite+vs.without+vs.noact;
    const tbtRow=D.tbt.r.find(t=>(v(t,TUI)||'').includes(sse)&&sse);
    const tbtLink=tbtRow?v(tbtRow,TBTLI):'';
    const dprLink=tbtRow?v(tbtRow,DPRLI):'';
    const tm=timeMap[email]||{};
    const dur=timeDiff(tm.minCI,tm.maxCO);
    return `<tr>
      <td style="color:var(--muted)">${i+1}</td>
      <td><div style="display:flex;align-items:center;gap:8px"><div class="avatar">${init}</div><div><div style="font-weight:500;font-size:13px">${name}</div><div style="font-size:11px;color:var(--muted)">${v(x,EI)}</div></div></div></td>
      <td><span class="badge bp">${sse||'—'}</span></td>
      <td style="font-size:12px">${v(x,DI)||'—'}</td>
      <td style="font-size:12px">${v(x,RI)||'—'}</td>
      <td style="font-size:12px">${v(x,CLI)||'—'}</td>
      <td style="font-size:12px">${v(x,CMI)||'—'}</td>
      <td>${attB}</td>
      <td><span class="badge bb">${visitMap[email]||0}</span></td>
      <td><span class="badge bg">${vs.onsite}</span></td>
      <td><span class="badge bo">${vs.without}</span></td>
      <td><span class="badge br">${vs.noact}</span></td>
      <td><span class="badge bp" style="font-weight:600">${totalAct}</span></td>
      <td>${getLinkBtn(tbtLink,'TBT Report')}</td>
      <td>${getLinkBtn(dprLink,'DPR Report')}</td>
      <td style="font-size:12px;white-space:nowrap">${fmtTime(tm.minCI)}</td>
      <td style="font-size:12px;white-space:nowrap">${fmtTime(tm.maxCO)}</td>
      <td style="font-size:12px;font-weight:500;color:${dur==='—'?'var(--muted)':'#34c98a'}">${dur}</td>
    </tr>`;
  }).join('');
}

