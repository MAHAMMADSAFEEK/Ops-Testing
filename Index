}

function buildAll(){buildPE();buildAtt();buildTBT();buildDPR();buildPOV();buildRPT();buildPMR();}

// ── PE ────────────────────────────────────────────────────────
function populatePEFilters(){
  const h=D.pe.h,r=D.pe.r;
  const CLI=ci(h,'Clusterhead','cluster'),CMI=ci(h,'CityManager','city');
  const clusters=[...new Set(r.map(x=>v(x,CLI)).filter(Boolean))].sort();
  const cities=[...new Set(r.map(x=>v(x,CMI)).filter(Boolean))].sort();
  const vsStatuses=[...new Set(D.att.r.map(x=>v(x,ci(D.att.h,'VisitStatus','status'))).filter(Boolean))].sort();

  // Build Month, Week, Date options from Attendance col B (Date)
  const _ADI=ci(D.att.h,'Date');
  const MONTH_NAMES=['January','February','March','April','May','June','July','August','September','October','November','December'];
  const monthSet=new Set(), weekSet=new Set(), dateSet=new Set();

  D.att.r.forEach(x=>{
    const raw=v(x,_ADI);
    if(!raw)return;
    const d=attDateObjStatic(raw);
    if(!d)return;
    const mo=d.getMonth()+1; // 1-12
    const day=d.getDate();
    const wk=day<=7?1:day<=14?2:day<=21?3:day<=28?4:5;
    // Store as "YYYY-MM" so months sort correctly across years
    monthSet.add(`${d.getFullYear()}-${String(mo).padStart(2,'0')}|${MONTH_NAMES[mo-1]} ${d.getFullYear()}`);
    weekSet.add(wk);
    // Store date as ISO for value, display as DD MMM YYYY
    const iso=`${d.getFullYear()}-${String(mo).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
    const disp=d.toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'});
    dateSet.add(`${iso}|${disp}`);
  });

  // Sort months chronologically
  const monthsSorted=[...monthSet].sort((a,b)=>a.localeCompare(b));
  // Sort dates chronologically
  const datesSorted=[...dateSet].sort((a,b)=>a.localeCompare(b));
  // Weeks always 1-5 but only include those present
  const weeksSorted=[...weekSet].sort((a,b)=>a-b);

  const selOpts=(id,entries,valFn,lblFn)=>{
    const s=document.getElementById(id);
    if(!s)return;
    const cur=s.value;
    while(s.options.length>1)s.remove(1);
    entries.forEach(e=>{
      const o=document.createElement('option');
      o.value=valFn(e); o.textContent=lblFn(e);
      if(o.value===cur)o.selected=true;
      s.appendChild(o);
    });
  };

  const sel=(id,vals)=>{const s=document.getElementById(id);if(!s)return;const cur=s.value;while(s.options.length>1)s.remove(1);vals.forEach(val=>{const o=document.createElement('option');o.value=val;o.textContent=val;if(val===cur)o.selected=true;s.appendChild(o);});};
  sel('pe-f-cluster',clusters);
  sel('pe-f-city',cities);
  sel('pe-f-vstatus',vsStatuses);

  // Month: value = "YYYY-MM", label = "January 2026"
  selOpts('pe-f-month', monthsSorted, e=>e.split('|')[0], e=>e.split('|')[1]);
  // Week: value = week number, label = "Week N (D–D)"
  const weekLabels={1:'Week 1 (1–7)',2:'Week 2 (8–14)',3:'Week 3 (15–21)',4:'Week 4 (22–28)',5:'Week 5 (29–31)'};
  selOpts('pe-f-week', weeksSorted, e=>String(e), e=>weekLabels[e]);
  // Date: value = ISO date "YYYY-MM-DD", label = "13 May 2026"
  selOpts('pe-f-date', datesSorted, e=>e.split('|')[0], e=>e.split('|')[1]);
}

// Static helper (no closure needed) for parsing att date strings
function attDateObjStatic(raw){
  if(!raw)return null;
  const p=raw.trim().split(/[\/\-]/);
  if(p.length>=3){
    // Try DD/MM/YYYY
    const d=new Date(`${p[2]}-${p[1].padStart(2,'0')}-${p[0].padStart(2,'0')}`);
    if(!isNaN(d)&&d.getFullYear()>2000)return d;
    // Try M/D/YYYY
    const d2=new Date(`${p[2]}-${p[0].padStart(2,'0')}-${p[1].padStart(2,'0')}`);
    if(!isNaN(d2)&&d2.getFullYear()>2000)return d2;
  }
  const d3=new Date(raw);
  return isNaN(d3)?null:d3;
}

function clearPEFilters(){
  ['pe-f-cluster','pe-f-city','pe-f-att','pe-f-month','pe-f-week','pe-f-date','pe-f-vstatus'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
