// ── PROJECT SUMMARY ───────────────────────────────────────────
let allProjects=[]; // [{name, id}]

function buildProjFilters(){
  const lh=D.lead.h,lr=D.lead.r;
  const PNI=ci(lh,'ProjectName','project name'),PII=ci(lh,'ProjectID','project id');
  const projMap={};
  lr.forEach(r=>{
    const pn=v(r,PNI),pi=v(r,PII);
    if(pn&&pi)projMap[pi]={name:pn,id:pi};
  });
  allProjects=Object.values(projMap).sort((a,b)=>a.name.localeCompare(b.name));
}

function highlight(text,query){
  if(!query)return text;
  const idx=text.toLowerCase().indexOf(query.toLowerCase());
  if(idx<0)return text;
  return text.slice(0,idx)+'<mark>'+text.slice(idx,idx+query.length)+'</mark>'+text.slice(idx+query.length);
}

function filterProjDropdown(type){
  const inputId=type==='name'?'proj-name-input':'proj-id-input';
  const ddId=type==='name'?'proj-name-dd':'proj-id-dd';
  const query=document.getElementById(inputId).value.trim().toLowerCase();
  const dd=document.getElementById(ddId);
  const filtered=query?allProjects.filter(p=>(type==='name'?p.name:p.id).toLowerCase().includes(query)):allProjects.slice(0,30);
  if(!filtered.length){dd.innerHTML='<div class="proj-dropdown-item no-results">No results found</div>';dd.classList.add('open');return;}
  dd.innerHTML=filtered.slice(0,40).map(p=>{
    const label=type==='name'?p.name:p.id;
    const sub=type==='name'?p.id:p.name;
    return `<div class="proj-dropdown-item" onmousedown="selectProj('${p.id.replace(/'/g,"\\'")}','${p.name.replace(/'/g,"\\'")}','${type}')">
      <div style="font-weight:500">${highlight(label,document.getElementById(inputId).value.trim())}</div>
      <div style="font-size:11px;color:var(--muted)">${sub}</div>
    </div>`;
  }).join('');
  dd.classList.add('open');
}

function openDropdown(type){
  filterProjDropdown(type);
}

function closeDropdownDelayed(type){
  setTimeout(()=>{
    const ddId=type==='name'?'proj-name-dd':'proj-id-dd';
    document.getElementById(ddId).classList.remove('open');
  },200);
}

function selectProj(id,name,type){
  document.getElementById('proj-name-input').value=name;
  document.getElementById('proj-id-input').value=id;
  document.getElementById('proj-name-dd').classList.remove('open');
  document.getElementById('proj-id-dd').classList.remove('open');
  renderProjectSummary(id,name);
}

function searchProject(){
  const nameVal=document.getElementById('proj-name-input').value.trim();
  const idVal=document.getElementById('proj-id-input').value.trim();
  // Try exact ID match first
  if(idVal){
    const match=allProjects.find(p=>p.id.toLowerCase()===idVal.toLowerCase());
    if(match){renderProjectSummary(match.id,match.name);return;}
    // fuzzy
    const fuzzy=allProjects.find(p=>p.id.toLowerCase().includes(idVal.toLowerCase()));
    if(fuzzy){renderProjectSummary(fuzzy.id,fuzzy.name);document.getElementById('proj-id-input').value=fuzzy.id;document.getElementById('proj-name-input').value=fuzzy.name;return;}
  }
  if(nameVal){
    const match=allProjects.find(p=>p.name.toLowerCase()===nameVal.toLowerCase());
    if(match){renderProjectSummary(match.id,match.name);document.getElementById('proj-id-input').value=match.id;return;}
    const fuzzy=allProjects.find(p=>p.name.toLowerCase().includes(nameVal.toLowerCase()));
    if(fuzzy){renderProjectSummary(fuzzy.id,fuzzy.name);document.getElementById('proj-id-input').value=fuzzy.id;document.getElementById('proj-name-input').value=fuzzy.name;return;}
  }
  alert('No project found. Try a different name or ID.');
}

function clearProjFilter(){
  document.getElementById('proj-name-input').value='';
  document.getElementById('proj-id-input').value='';
  document.getElementById('proj-name-dd').classList.remove('open');
  document.getElementById('proj-id-dd').classList.remove('open');
  document.getElementById('proj-summary-area').style.display='none';
  document.getElementById('proj-empty').style.display='block';
  document.getElementById('proj-info-bar').style.display='none';
}

// Also allow Enter key to trigger search
document.addEventListener('DOMContentLoaded',()=>{
  ['proj-name-input','proj-id-input'].forEach(id=>{
    document.getElementById(id)?.addEventListener('keydown',e=>{if(e.key==='Enter')searchProject();});
  });
});

function renderProjectSummary(projId,projName){
  if(!projId){clearProjFilter();return;}

  // ── Step 1: Find all Attendance Tracker rows for this project
  const ah=D.att.h,ar=D.att.r;
  const A_UID=ci(ah,'UniqueID','unique id');  // col A - Unique ID
  const A_DATE=ci(ah,'Date');                  // col B - Date
  const A_PNAME=ci(ah,'ProjectName','project name'); // col C - Project Name
  const A_PID=ci(ah,'ProjectID','project id');       // col D - Project ID

  // Get all unique IDs (col A) where Project ID (col D) matches
  const attRowsForProj=ar.filter(r=>v(r,A_PID)===projId);
  const uniqueIdsForProj=new Set(attRowsForProj.map(r=>v(r,A_UID)).filter(Boolean));

  // ── Step 2: Get all DPR rows matching those unique IDs
  const dh=D.dpr.h,dr=D.dpr.r;
  const D_CID=ci(dh,'ChildID','child');         // Child ID like SSHS_1507/13-May-2026
  const D_PLAN=ci(dh,'WorkPlan','plan','work'); // Today's Work Plan
  const D_MP=ci(dh,'Manpower');
  const D_TASK=ci(dh,'CompletedTask','completed task');
  const D_PCT=ci(dh,'%','completion','percent');
  const D_ISS=ci(dh,'Issues','challenges');
  const D_REM=ci(dh,'Remarks','remark');
  const D_TS=ci(dh,'Timestamp','time');
  const D_UID=ci(dh,'UniqueID','unique');

  // DPR Child ID format: SSHS_1507/13-May-2026(xxx)
  // Unique ID in DPR is col L (Unique ID)
  // We need to match DPR rows where Unique ID exists in uniqueIdsForProj
  // OR Child ID starts with projId
  const dprForProj=dr.filter(r=>{
    const uid=v(r,D_UID);
    const cid=v(r,D_CID);
    // Match by unique id OR by child id containing project ID
    return uniqueIdsForProj.has(uid) || cid.startsWith(projId);
  });

  // ── Step 3: Get workplan items
  const wh=D.workplan.h,wr=D.workplan.r;
  // Build workplan with A=process, B=expected completion %
  const workplanItemsRaw=wr.filter(r=>(r[0]||'').trim()).map(r=>({
    plan:(r[0]||'').trim(),
    expectedPct:parseFloat((r[1]||'').trim())||0
  }));
  const workplanItems=workplanItemsRaw.map(w=>w.plan);

  // ── Step 4: For each workplan item, find latest DPR entry
  // Group DPR by work plan
  const dprByPlan={};
  dprForProj.forEach(r=>{
    const plan=v(r,D_PLAN).trim().toLowerCase();
    if(!plan)return;
    if(!dprByPlan[plan])dprByPlan[plan]=[];
    dprByPlan[plan].push(r);
  });

  // Helper: normalize plan name for matching
  const norm=s=>s.trim().toLowerCase().replace(/[^a-z0-9]/g,'');

  // ── Step 5: Build workplan table
  const tbody=document.getElementById('proj-workplan-body');
  let completedCount=0,wipCount=0,pendingCount=0;

  const rows=workplanItemsRaw.map(({plan,expectedPct},idx)=>{
    const planNorm=norm(plan);
    // Find matching DPR entries (fuzzy match)
    const matchedDPR=dprForProj.filter(r=>{
      const dp=norm(v(r,D_PLAN));
      return dp===planNorm||dp.includes(planNorm)||planNorm.includes(dp);
    });

    if(!matchedDPR.length){
      pendingCount++;
      return{plan,expectedPct,status:'pending',pct:0,mp:0,startDate:null,endDate:null,remarks:'',matchedDPR:[]};
    }

    // Sort by timestamp to get latest
    const sorted=[...matchedDPR].sort((a,b)=>{
      const da=parseDate(v(a,D_TS)),db=parseDate(v(b,D_TS));
      if(!da&&!db)return 0;if(!da)return 1;if(!db)return -1;
      return da-db;
    });
    const latest=sorted[sorted.length-1];
    const latestPct=parseFloat(v(latest,D_PCT))||0;
    const latestTask=v(latest,D_TASK).toLowerCase();
    const allDates=sorted.map(r=>parseDate(v(r,D_TS))).filter(Boolean);
    const startDate=allDates.length?allDates[0]:null;
    const endDate=allDates.length?allDates[allDates.length-1]:null;
    const totalMP=matchedDPR.reduce((s,r)=>s+(parseInt(v(r,D_MP))||0),0);
    const latestRemarks=v(latest,D_REM);

    let status,pct;
    if(latestTask.includes('complet')||latestPct>=100){status='done';pct=100;completedCount++;}
    else{status='wip';pct=latestPct;wipCount++;}

    return{plan,expectedPct,status,pct,mp:totalMP,startDate,endDate,remarks:latestRemarks,matchedDPR:sorted};
  });

  pendingCount=workplanItems.length-completedCount-wipCount;

  tbody.innerHTML=rows.map((r,i)=>{
    let statusBadge,progBar;
    if(r.status==='done'){
      statusBadge='<span class="badge bg">✓ Completed</span>';
      progBar=`<div class="pbar-wrap"><div class="pbar"><div class="pbar-fill" style="width:100%;background:#34c98a;"></div></div><span class="pct-lbl" style="color:#34c98a;">100%</span></div>`;
    } else if(r.status==='wip'){
      const pct=r.pct;
      const col=pct>=75?'#34c98a':pct>=50?'#4f8ef7':pct>=25?'#f5a623':'#e74c3c';
      statusBadge=`<span class="badge bo">⟳ Work In Progress</span>`;
      progBar=`<div class="pbar-wrap"><div class="pbar"><div class="pbar-fill" style="width:${pct}%;background:${col};"></div></div><span class="pct-lbl">${pct}%</span></div>`;
    } else {
      statusBadge='<span class="badge bgr">— Pending</span>';
      progBar=`<div class="pbar-wrap"><div class="pbar"><div class="pbar-fill" style="width:0%;"></div></div><span class="pct-lbl">0%</span></div>`;
    }
    const days=r.startDate&&r.endDate?Math.ceil((r.endDate-r.startDate)/(1000*60*60*24))+1:'—';
    return `<tr>
      <td style="color:var(--muted)">${i+1}</td>
      <td style="font-weight:500">${r.plan}</td>
      <td><div>${statusBadge}</div><div style="margin-top:6px;" class="progress-col">${progBar}</div></td>
      <td>${r.mp||'—'}</td>
      <td style="font-size:11px;white-space:nowrap">${r.startDate?fmtDate(r.startDate):'—'}</td>
      <td style="font-size:11px;white-space:nowrap">${r.endDate?fmtDate(r.endDate):'—'}</td>
      <td>${days}</td>
      <td style="font-size:11px;color:var(--muted);max-width:150px;overflow:hidden;text-overflow:ellipsis">${r.remarks||'—'}</td>
    </tr>`;
  }).join('');

  // ── Overall project dates from DPR timestamps
  const allProjDates=dprForProj.map(r=>parseDate(v(r,D_TS))).filter(Boolean);
  const projStartDate=allProjDates.length?new Date(Math.min(...allProjDates)):null;
  const projEndDate=allProjDates.length?new Date(Math.max(...allProjDates)):null;
  const today=new Date(); today.setHours(0,0,0,0);
  const projTAT=projStartDate?Math.ceil((today-projStartDate)/(1000*60*60*24))+1:null;

  // ── Weighted completion % from Workplan B column (expected %)
  // For each completed item, add its expectedPct; for WIP add proportional; pending = 0
  let weightedCompleted=0,totalWeight=0;
  rows.forEach(r=>{
    const w=r.expectedPct||0;
    totalWeight+=w;
    if(r.status==='done') weightedCompleted+=w;
    else if(r.status==='wip') weightedCompleted+=w*(r.pct/100);
  });
  const weightedPct=totalWeight>0?Math.round(weightedCompleted/totalWeight*100):0;

  // Simple counts
  const total_=workplanItems.length;
  const completedPct=total_?Math.round(completedCount/total_*100):0;
  const wipPct=total_?Math.round(wipCount/total_*100):0;
  const pendingPct=total_?Math.round(pendingCount/total_*100):0;

  // ── DPR sorted for log + last updated
  const dprSorted=[...dprForProj].sort((a,b)=>{
    const da=parseDate(v(a,D_TS)),db=parseDate(v(b,D_TS));
    if(!da&&!db)return 0;if(!da)return 1;if(!db)return -1;
    return db-da; // newest first
  });
  const lastDPREntry=dprSorted.length?dprSorted[0]:null;
  const lastWorkPlan=lastDPREntry?v(lastDPREntry,D_PLAN):'—';
  const lastDPRDate=lastDPREntry?parseDate(v(lastDPREntry,D_TS)):null;

  const tatCard=`<div class="metric" style="--mc:#4f8ef7;grid-column:span 2;min-width:280px;">
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
      <i class="ti ti-calendar-stats" style="font-size:16px;color:#4f8ef7;"></i>
      <span style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em;font-weight:500;">Project Timeline</span>
    </div>
    <div style="display:flex;flex-direction:column;gap:10px;">
      <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 10px;background:var(--bg2);border-radius:8px;">
        <span style="font-size:11px;color:var(--muted);display:flex;align-items:center;gap:6px;"><i class="ti ti-calendar-event" style="font-size:13px;color:#34c98a;"></i>Start Date</span>
        <span style="font-size:13px;font-weight:600;color:#34c98a;">${projStartDate?fmtDate(projStartDate):'—'}</span>
      </div>
      <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 10px;background:var(--bg2);border-radius:8px;">
        <span style="font-size:11px;color:var(--muted);display:flex;align-items:center;gap:6px;"><i class="ti ti-calendar-check" style="font-size:13px;color:#f5a623;"></i>End Date</span>
        <span style="font-size:13px;font-weight:600;color:#f5a623;">${projEndDate?fmtDate(projEndDate):'—'}</span>
      </div>
      <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 10px;background:var(--bg2);border-radius:8px;">
        <span style="font-size:11px;color:var(--muted);display:flex;align-items:center;gap:6px;"><i class="ti ti-clock-hour-4" style="font-size:13px;color:#34c98a;"></i>TAT (Today − Start)</span>
        <span style="font-size:13px;font-weight:700;color:#34c98a;">${projTAT!==null?projTAT+' days':'—'}</span>
      </div>
    </div>
  </div>`;

  // Pending from = Today - Last DPR Date
  const pendingFromDays=lastDPRDate?Math.ceil((today-lastDPRDate)/(1000*60*60*24)):null;

  const lastUpdatedCard=`<div class="metric" style="--mc:#4f8ef7;grid-column:span 2;min-width:280px;">
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
      <i class="ti ti-history" style="font-size:16px;color:#4f8ef7;"></i>
      <span style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em;font-weight:500;">Last DPR Update</span>
    </div>
    <div style="display:flex;flex-direction:column;gap:10px;">
      <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 10px;background:var(--bg2);border-radius:8px;">
        <span style="font-size:11px;color:var(--muted);display:flex;align-items:center;gap:6px;"><i class="ti ti-calendar" style="font-size:13px;color:#4f8ef7;"></i>Last Updated</span>
        <span style="font-size:13px;font-weight:600;color:#4f8ef7;">${lastDPRDate?fmtDate(lastDPRDate):'—'}</span>
      </div>
      <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 10px;background:rgba(231,76,60,0.1);border-radius:8px;border:1px solid rgba(231,76,60,0.25);">
        <span style="font-size:11px;color:var(--muted);display:flex;align-items:center;gap:6px;"><i class="ti ti-alert-triangle" style="font-size:13px;color:#e74c3c;"></i>Pending From</span>
        <span style="font-size:13px;font-weight:700;color:#e74c3c;">${pendingFromDays!==null?pendingFromDays+' days':'—'}</span>
      </div>
      <div style="padding:6px 10px;background:var(--bg2);border-radius:8px;">
        <div style="font-size:11px;color:var(--muted);margin-bottom:4px;display:flex;align-items:center;gap:6px;"><i class="ti ti-clipboard-list" style="font-size:13px;color:#34c98a;"></i>Work Plan</div>
        <div style="font-size:12px;font-weight:500;color:var(--text);line-height:1.4;">${lastWorkPlan||'—'}</div>
      </div>
    </div>
  </div>`;

  document.getElementById('proj-metrics').innerHTML=
    metricWithBar('ti-list-check','Total Items',total_,'Workplan items','#4f8ef7',100,100)+
    metricWithBar('ti-circle-check','Completed',completedCount,`${completedPct}% of items`,'#34c98a',completedPct,'#34c98a')+
    metricWithBar('ti-loader','In Progress',wipCount,`${wipPct}% of items`,'#f5a623',wipPct,'#f5a623')+
    metricWithBar('ti-clock','Pending',pendingCount,`${pendingPct}% of items`,'#e74c3c',pendingPct,'#e74c3c')+
    metricWithBar('ti-file-report','DPR Entries',dprForProj.length,'For this project','#9b6dff',100,'#9b6dff')+
    metricWithBar('ti-chart-donut','Completion %',weightedPct+'%','Weighted by workplan %','#34c98a',weightedPct,'#34c98a')+
    tatCard+
    lastUpdatedCard;

  // ── DPR Activity Log (filterable by TBT "DPR Summary" link; match on column A)
  _projDPRSorted=dprSorted;
  _projDPRCols={D_PLAN,D_TASK,D_PCT,D_MP,D_ISS,D_REM,D_TS};
  _dprLogFilterUid=null;
  renderProjDPRLog();

  // ── TBT Log (TBT sheet, fixed columns; scoped to this project's unique IDs via col A)
  const th=D.tbt.h,tr=D.tbt.r;
  const T_UID=0,T_VENDOR=1,T_TOPIC=2,T_TECH=3,T_HELP=4,T_ATTEND=5,T_REMARK=6,T_DATE=8,T_TBTREP=12,T_DPRREP=13;
  const tbtForProj=tr.filter(x=>uniqueIdsForProj.has(v(x,T_UID)))
    .sort((a,b)=>{const da=parseDate(v(a,T_DATE)),db=parseDate(v(b,T_DATE));if(!da&&!db)return 0;if(!da)return 1;if(!db)return -1;return db-da;});
  const tbtBody=document.getElementById('proj-tbt-log-body');
  const tbtLink=(url,label,color)=>{
    if(!url||!url.trim().startsWith('http'))return '<span style="color:var(--muted);font-size:11px;">—</span>';
    return `<a href="${url.trim()}" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:4px;padding:3px 8px;background:${color}22;color:${color};border:1px solid ${color}55;border-radius:6px;font-size:11px;font-weight:500;text-decoration:none;"><i class="ti ti-folder-open" style="font-size:12px;"></i>${label}</a>`;
  };
  tbtBody.innerHTML=tbtForProj.map((x,i)=>{
    const uid=v(x,T_UID);
    const dt=parseDate(v(x,T_DATE));
    const escUid=uid.replace(/'/g,"\\'");
    const dprSumLink=`<a onclick="dprLogFilterById('${escUid}')" style="display:inline-flex;align-items:center;gap:4px;padding:3px 8px;background:rgba(79,142,247,0.15);color:#4f8ef7;border:1px solid rgba(79,142,247,0.3);border-radius:6px;font-size:11px;font-weight:500;text-decoration:none;cursor:pointer;"><i class="ti ti-filter" style="font-size:12px;"></i>DPR Summary</a>`;
    return `<tr>
      <td style="color:var(--muted)">${i+1}</td>
      <td style="font-size:11px;white-space:nowrap">${dt?fmtDate(dt):v(x,T_DATE)||'—'}</td>
      <td style="font-size:12px">${v(x,T_VENDOR)||'—'}</td>
      <td style="font-size:12px;max-width:160px;overflow:hidden;text-overflow:ellipsis" title="${v(x,T_TOPIC).replace(/"/g,'&quot;')}">${v(x,T_TOPIC)||'—'}</td>
      <td>${v(x,T_TECH)||'—'}</td>
      <td>${v(x,T_HELP)||'—'}</td>
      <td style="font-size:11px;max-width:160px;overflow:hidden;text-overflow:ellipsis" title="${v(x,T_ATTEND).replace(/"/g,'&quot;')}">${v(x,T_ATTEND)||'—'}</td>
      <td style="font-size:11px;color:var(--muted);max-width:120px;overflow:hidden;text-overflow:ellipsis">${v(x,T_REMARK)||'—'}</td>
      <td>${tbtLink(v(x,T_TBTREP),'TBT Report','#34c98a')}</td>
      <td>${tbtLink(v(x,T_DPRREP),'DPR Report','#9b6dff')}</td>
      <td>${dprSumLink}</td>
    </tr>`;
  }).join('');
  if(!tbtForProj.length){tbtBody.innerHTML='<tr><td colspan="11" class="empty">No TBT entries found for this project</td></tr>';}

  // ── Info bar
  const infoBar=document.getElementById('proj-info-bar');
  infoBar.style.display='flex';
  infoBar.innerHTML=`
    <span><strong>${projName}</strong></span>
    <span>ID: <strong>${projId}</strong></span>
    <span>Attendance entries: <strong>${attRowsForProj.length}</strong></span>
    <span>Unique IDs tracked: <strong>${uniqueIdsForProj.size}</strong></span>
    <span>DPR records: <strong>${dprForProj.length}</strong></span>
  `;

  document.getElementById('proj-summary-area').style.display='block';
  document.getElementById('proj-empty').style.display='none';
}

// ── DPR Activity Log render + filter (driven by TBT "DPR Summary" link; matches column A)
let _projDPRSorted=[], _projDPRCols=null, _dprLogFilterUid=null;

function renderProjDPRLog(){
  const logBody=document.getElementById('proj-dpr-log-body');
  if(!logBody||!_projDPRCols)return;
  const {D_PLAN,D_TASK,D_PCT,D_MP,D_ISS,D_REM,D_TS}=_projDPRCols;
  // Filter on column A (index 0) when a TBT unique ID is active
  const rows=_dprLogFilterUid?_projDPRSorted.filter(r=>v(r,0)===_dprLogFilterUid):_projDPRSorted;

  // Filter indicator next to the card title
  const tag=document.getElementById('proj-dpr-log-filter');
  if(tag){
    if(_dprLogFilterUid){tag.style.display='inline-flex';tag.innerHTML=`<span class="pe-active-tag" style="cursor:pointer;align-self:center;" onclick="clearDPRLogFilter()"><i class="ti ti-filter" style="font-size:11px;"></i> ID: ${_dprLogFilterUid} · clear ✕</span>`;}
    else {tag.style.display='none';tag.innerHTML='';}
  }

  logBody.innerHTML=rows.map((r,i)=>{
    const pct=parseFloat(v(r,D_PCT))||0,pc=pct>=75?'bg':pct>=50?'bb':pct>=25?'bo':'br';
    const iss=v(r,D_ISS),hasIss=iss&&iss.toLowerCase()!=='no'&&iss.toLowerCase()!=='none'&&iss.toLowerCase()!=='na';
    const ts=parseDate(v(r,D_TS));
    return `<tr>
      <td style="color:var(--muted)">${i+1}</td>
      <td style="font-size:11px;white-space:nowrap">${ts?fmtDate(ts):v(r,D_TS)||'—'}</td>
      <td style="font-size:12px;max-width:160px;overflow:hidden;text-overflow:ellipsis">${v(r,D_PLAN)||'—'}</td>
      <td style="font-size:12px;max-width:160px;overflow:hidden;text-overflow:ellipsis">${v(r,D_TASK)||'—'}</td>
      <td><span class="badge ${pc}">${pct}%</span></td>
      <td>${v(r,D_MP)||'—'}</td>
      <td>${hasIss?'<span class="badge br">⚠ Yes</span>':'<span class="badge bg">None</span>'}</td>
      <td style="font-size:11px;color:var(--muted);max-width:120px;overflow:hidden;text-overflow:ellipsis">${v(r,D_REM)||'—'}</td>
    </tr>`;
  }).join('');
  if(!rows.length){logBody.innerHTML=`<tr><td colspan="8" class="empty">${_dprLogFilterUid?'No DPR entries for ID '+_dprLogFilterUid:'No DPR entries found for this project'}</td></tr>`;}
}

function dprLogFilterById(uid){
  _dprLogFilterUid=uid;
  renderProjDPRLog();
  const el=document.getElementById('proj-dpr-log-body');
  if(el)el.closest('.card').scrollIntoView({behavior:'smooth',block:'start'});
}

function clearDPRLogFilter(){
  _dprLogFilterUid=null;
  renderProjDPRLog();
}

// ── PROJECT OVERVIEW ──────────────────────────────────────────
// Lead Tracker fixed column indices (letters → 0-based index)
const LEAD_COL={TOTAL:0,PID:1,CITY:2,PNAME:3,SIZE:5,CLUSTER:30,CITYMGR:32,PE:34};
let _povCache={};

// Safe Lead-row cell getter by fixed index
function lv(row,i){return (i>=0 && row[i]!=null)?String(row[i]).trim():'';}

// Parse a size/capacity value, stripping any non-numeric characters
function povNum(s){if(!s)return 0;const n=parseFloat(String(s).replace(/[^0-9.\-]/g,''));return isNaN(n)?0:n;}

// Multi-select state: selected values per filter + full option lists
const POV_STATUSES=['Not Assigned','Completed','In Process','Pending'];
const POV_MS_CFG={
  city:    {col:'CITY',    all:'All Cities',    ph:'Search cities…'},
  cluster: {col:'CLUSTER', all:'All Clusters',  ph:'Search clusters…'},
  citymgr: {col:'CITYMGR', all:'All City Mgrs', ph:'Search city managers…'},
  pe:      {col:'PE',      all:'All PEs',        ph:'Search PEs…'},
  status:  {col:null,      all:'All Statuses',   ph:'Search status…', fixed:POV_STATUSES}
};
let _povMS={city:new Set(),cluster:new Set(),citymgr:new Set(),pe:new Set(),status:new Set()};
let _povMSAll={city:[],cluster:[],citymgr:[],pe:[],status:POV_STATUSES.slice()};
let _povMSCounts={city:{},cluster:{},citymgr:{},pe:{},status:{}};

// Status tags for a lead row (a project may be "Not Assigned" plus one of done/wip/pending)
function povProjectStatuses(x){
  const tags=[];
  if(!lv(x,LEAD_COL.PE))tags.push('Not Assigned');
  const m=computeProjectMetrics(lv(x,LEAD_COL.PID));
  if(m.status==='done')tags.push('Completed');
  else if(m.status==='wip')tags.push('In Process');
  else tags.push('Pending');
  return tags;
}

function populatePOVFilters(){
  const r=D.lead.r;
  const sets={city:new Set(),cluster:new Set(),citymgr:new Set(),pe:new Set()};
  r.forEach(x=>{
    if(!lv(x,LEAD_COL.PID))return;
    const c=lv(x,LEAD_COL.CITY); if(c)sets.city.add(c);
    const ch=lv(x,LEAD_COL.CLUSTER); if(ch)sets.cluster.add(ch);
    const cm=lv(x,LEAD_COL.CITYMGR); if(cm)sets.citymgr.add(cm);
    const pe=lv(x,LEAD_COL.PE); if(pe)sets.pe.add(pe);
  });
  Object.keys(sets).forEach(k=>{
    _povMSAll[k]=[...sets[k]].sort((a,b)=>a.localeCompare(b));
    // drop any previously-selected values that no longer exist
    _povMS[k]=new Set([..._povMS[k]].filter(v=>sets[k].has(v)));
  });
  // status: fixed list; prune selections to valid values
  _povMSAll.status=POV_STATUSES.slice();
  _povMS.status=new Set([..._povMS.status].filter(v=>POV_STATUSES.includes(v)));
  Object.keys(POV_MS_CFG).forEach(buildPOVMSWidget);
  recomputePOVOptions();
}

